    async function updateTwitchUserRole(action, role, targetUsername) {
        const broadcasterId = currentConfig.resolved_broadcaster_id;
        if (!broadcasterId) return;
        let token = await getValidToken();
        if (!token) return;

        const targetUserId = await resolveUserId(targetUsername);
        if (!targetUserId) return;

        logMsg(`[Twitch API] ${action === 'add' ? 'Adding' : 'Removing'} ${targetUsername} as ${role}...`);
        try {
            let url = '';
            let method = action === 'add' ? 'POST' : 'DELETE';
            
            if (role === 'moderator') {
                url = `https://api.twitch.tv/helix/moderation/moderators?broadcaster_id=${broadcasterId}&user_id=${targetUserId}`;
            } else if (role === 'vip') {
                url = `https://api.twitch.tv/helix/channels/vips?broadcaster_id=${broadcasterId}&user_id=${targetUserId}`;
            }

            const response = await fetch(url, {
                method: method,
                headers: {
                    'Client-Id': CLIENT_ID,
                    'Authorization': `Bearer ${token}`
                }
            });

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Twitch API Error] Failed to update user role: ${response.status} - ${errText}`, true);
            } else {
                logMsg(`[Twitch API] Successfully ${action === 'add' ? 'added' : 'removed'} ${targetUsername} as ${role}.`);
            }
        } catch(e) {
            logMsg(`[Twitch API Error] Error updating user role: ${e.message}`, true);
        }
    }

    async function resolveTwitchGameId(gameNameOrId) {
        if (!gameNameOrId) return "";
        const trimmed = String(gameNameOrId).trim();
        // If it looks like a numeric ID already, return it directly
        if (/^\d+$/.test(trimmed)) {
            return trimmed;
        }

        let token = await getValidToken();
        if (!token) return "";

        try {
            const response = await fetch(`https://api.twitch.tv/helix/games?name=${encodeURIComponent(trimmed)}`, {
                headers: {
                    'Client-Id': CLIENT_ID,
                    'Authorization': `Bearer ${token}`
                }
            });
            if (response.ok) {
                const data = await response.json();
                if (data && data.data && data.data.length > 0) {
                    // Try to find exact match case-insensitive
                    const match = data.data.find(g => g.name.toLowerCase() === trimmed.toLowerCase()) || data.data[0];
                    return match.id;
                }
            }
        } catch (e) {
            logMsg(`[Twitch API Warning] Failed to resolve game name "${trimmed}": ${e.message}`);
        }
        return trimmed; // Fallback
    }

    async function updateTwitchStreamInfo(title, gameNameOrId) {
        const broadcasterId = currentConfig.resolved_broadcaster_id;
        if (!broadcasterId) return;

        let gameId = "";
        if (gameNameOrId) {
            gameId = await resolveTwitchGameId(gameNameOrId);
        }

        let token = await getValidToken();
        if (!token) return;

        logMsg(`[Twitch API] Updating stream title to "${title}" (gameId: ${gameId || 'none'})...`);
        try {
            const payload = {};
            if (title) payload.title = title;
            if (gameId) payload.game_id = gameId;

            const response = await fetch(`https://api.twitch.tv/helix/channels?broadcaster_id=${broadcasterId}`, {
                method: 'PATCH',
                headers: {
                    'Client-Id': CLIENT_ID,
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Twitch API Error] Failed to update stream info: ${response.status} - ${errText}`, true);
            } else {
                logMsg(`[Twitch API] Stream info updated successfully.`);
            }
        } catch(e) {
            logMsg(`[Twitch API Error] Error updating stream info: ${e.message}`, true);
        }
    }

    // ─── Guest Star: Fetch Active Session ────────────────────────────────────
    async function fetchGuestStarSession() {
        const broadcasterId = currentConfig.resolved_broadcaster_id;
        if (!broadcasterId) {
            logMsg("[Twitch API Error] Broadcaster ID not resolved.", true);
            return null;
        }
        let token = await getValidToken();
        if (!token) return null;

        logMsg("[Twitch API] Fetching active Guest Star session...");
        try {
            const response = await fetch(`https://api.twitch.tv/helix/guest_star/session?broadcaster_id=${broadcasterId}&moderator_id=${broadcasterId}`, {
                method: 'GET',
                headers: { 'Client-Id': CLIENT_ID, 'Authorization': `Bearer ${token}` }
            });

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Twitch API Error] Failed to fetch Guest Star session: ${response.status} - ${errText}`, true);
                return null;
            }

            const data = await response.json();
            const session = data.data && data.data[0];
            if (session && session.id) {
                currentConfig.guest_star_session_id = session.id;
                logMsg(`[Twitch API] Active Guest Star session found. Session ID stored: ${session.id} (${session.guests ? session.guests.length : 0} guest(s) in session).`);
                return session;
            } else {
                currentConfig.guest_star_session_id = null;
                logMsg("[Twitch API] No active Guest Star session found.");
                return null;
            }
        } catch(e) {
            logMsg(`[Twitch API Error] Error fetching Guest Star session: ${e.message}`, true);
            return null;
        }
    }

    // ─── Channel Points Reward Enable/Disable ─────────────────────────────────
    async function updateCustomReward(rewardNameOrId, enabled) {
        const broadcasterId = currentConfig.resolved_broadcaster_id;
        if (!broadcasterId) {
            logMsg("[Twitch API Error] Broadcaster ID is not resolved yet.", true);
            return;
        }
        let token = await getValidToken();
        if (!token) return;

        // Find the reward ID — try matching by title or treat as direct ID
        let rewardId = rewardNameOrId;
        const byTitle = customRewardsList.find(r => r.title.toLowerCase() === (rewardNameOrId || "").toLowerCase());
        if (byTitle) {
            rewardId = byTitle.id;
        }

        if (!rewardId) {
            logMsg(`[Twitch API Error] Could not find reward: "${rewardNameOrId}"`, true);
            return;
        }

        logMsg(`[Twitch API] ${enabled ? 'Enabling' : 'Disabling'} custom reward "${rewardNameOrId}" (${rewardId})...`);
        try {
            const response = await fetch(`https://api.twitch.tv/helix/channel_points/custom_rewards?broadcaster_id=${broadcasterId}&id=${rewardId}`, {
                method: 'PATCH',
                headers: {
                    'Client-Id': CLIENT_ID,
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ is_enabled: enabled })
            });

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Twitch API Error] Failed to update reward: ${response.status} - ${errText}`, true);
            } else {
                logMsg(`[Twitch API] Reward "${rewardNameOrId}" ${enabled ? 'enabled' : 'disabled'} successfully.`);
                // Refresh the local list
                fetchTwitchCustomRewards();
            }
        } catch(e) {
            logMsg(`[Twitch API Error] Error updating reward: ${e.message}`, true);
        }
    }

