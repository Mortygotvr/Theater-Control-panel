    async function updateGuestStarSlotSettings(slotId, settings) {
        const broadcasterId = currentConfig.resolved_broadcaster_id;
        if (!broadcasterId) { logMsg("[Twitch API Error] Broadcaster ID not resolved.", true); return; }
        let token = await getValidToken();
        if (!token) return;

        logMsg(`[Twitch API] Updating Guest Star slot ${slotId} settings: ${JSON.stringify(settings)}...`);
        try {
            const params = new URLSearchParams({
                broadcaster_id: broadcasterId,
                moderator_id: broadcasterId,
                session_id: currentConfig.guest_star_session_id || "",
                slot_id: slotId
            });
            const response = await fetch(`https://api.twitch.tv/helix/guest_star/slot_settings?${params.toString()}`, {
                method: 'PATCH',
                headers: {
                    'Client-Id': CLIENT_ID,
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(settings)
            });
            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Twitch API Error] Guest Star update slot settings failed: ${response.status} - ${errText}`, true);
            } else {
                logMsg(`[Twitch API] Guest Star slot ${slotId} settings updated.`);
            }
        } catch(e) { logMsg(`[Twitch API Error] Guest Star slot settings error: ${e.message}`, true); }
    }

    function replaceTemplateVariables(text, matches, payload) {
        let result = text || "";
        
        if (matches && Array.isArray(matches)) {
            matches.forEach((val, idx) => {
                result = result.replace(new RegExp(`\\{${idx + 1}\\}`, 'g'), val !== undefined ? val : "");
            });
        }
        
        if (!payload) return result;

        return result.replace(/\{([a-zA-Z0-9_\.\[\]]+)(?:\s*\|\s*([^}]+))?\}/g, (match, path, fallback) => {
            let val = getNestedValue(payload, path);
            if (val === undefined && payload.customData) {
                val = getNestedValue(payload.customData, path);
            }
            if (val !== undefined && val !== null && typeof val !== 'object') {
                return val;
            }
            if (fallback !== undefined) {
                return fallback.trim();
            }
            const rootKey = path.split('.')[0].replace(/\[\d+\]/g, '');
            if (payload[rootKey] !== undefined || (payload.customData && payload.customData[rootKey] !== undefined)) {
                return "";
            }
            return match;
        });
    }

    function getNestedValue(obj, path) {
        if (obj === null || obj === undefined) return undefined;
        const cleanPath = path.replace(/\[(\d+)\]/g, '.$1');
        return cleanPath.split('.').reduce((acc, part) => {
            return (acc && acc[part] !== undefined) ? acc[part] : undefined;
        }, obj);
    }

    // Automatically migrate legacy triggers & commands to the new unified event schemas
    function migrateOldTriggersAndCommands() {
        if (!window.config || !Array.isArray(window.config.triggers)) return;

        let migratedAny = false;

        window.config.triggers.forEach(t => {
            // 1. Migrate Triggers
            if (t.triggerType && t.triggerType.startsWith("twitch_") && t.triggerType !== "twitch_event") {
                const oldType = t.triggerType;
                t.triggerType = "twitch_event";
                migratedAny = true;

                if (oldType === "twitch_chat_message" || oldType === "twitch_message") {
                    t.eventType = "message";
                } else if (oldType === "twitch_subscription") {
                    t.eventType = "subscription";
                } else if (oldType === "twitch_gifted_subscription") {
                    t.eventType = "gifted_subscription";
                } else if (oldType === "twitch_host") {
                    t.eventType = "host";
                } else if (oldType === "twitch_user_banned") {
                    t.eventType = "user_banned";
                } else if (oldType === "twitch_user_timeout") {
                    t.eventType = "user_timeout";
                } else if (oldType === "twitch_message_deleted") {
                    t.eventType = "message_deleted";
                } else if (oldType === "twitch_chat_cleared") {
                    t.eventType = "chat_cleared";
                }
                logMsg(`[Twitch API] Migrated legacy trigger type "${oldType}" to "twitch_event" (eventType: "${t.eventType}")`);
            }

            // 2. Migrate Commands inside Triggers
            if (Array.isArray(t.commands)) {
                t.commands.forEach(cmd => {
                    if (cmd.type && cmd.type.startsWith("twitch_") && cmd.type !== "twitch_command") {
                        const oldCmdType = cmd.type;
                        cmd.type = "twitch_command";
                        migratedAny = true;

                        if (oldCmdType === "twitch_send_message") {
                            cmd.commandType = "send_message";
                        } else if (oldCmdType === "twitch_ban_user") {
                            cmd.commandType = "ban_user";
                        } else if (oldCmdType === "twitch_timeout_user") {
                            cmd.commandType = "timeout_user";
                        } else if (oldCmdType === "twitch_unban_user") {
                            cmd.commandType = "unban_user";
                        } else if (oldCmdType === "twitch_clear_chat") {
                            cmd.commandType = "clear_chat";
                        } else if (oldCmdType === "twitch_shoutout") {
                            cmd.commandType = "shoutout";
                        } else if (oldCmdType === "twitch_announce") {
                            cmd.commandType = "announce";
                        } else if (oldCmdType === "twitch_add_moderator") {
                            cmd.commandType = "add_moderator";
                        } else if (oldCmdType === "twitch_remove_moderator") {
                            cmd.commandType = "remove_moderator";
                        } else if (oldCmdType === "twitch_add_vip") {
                            cmd.commandType = "add_vip";
                        } else if (oldCmdType === "twitch_remove_vip") {
                            cmd.commandType = "remove_vip";
                        } else if (oldCmdType === "twitch_slow_mode") {
                            cmd.commandType = "slow_mode";
                        } else if (oldCmdType === "twitch_follower_only") {
                            cmd.commandType = "follower_only";
                        } else if (oldCmdType === "twitch_subscriber_only") {
                            cmd.commandType = "subscriber_only";
                        } else if (oldCmdType === "twitch_emote_only") {
                            cmd.commandType = "emote_only";
                        } else if (oldCmdType === "twitch_update_stream") {
                            cmd.commandType = "update_stream";
                        }
                        logMsg(`[Twitch API] Migrated legacy command type "${oldCmdType}" to "twitch_command" (commandType: "${cmd.commandType}")`);
                    }
                });
            }
        });

        // 3. Migrate legacy commands stored in button grid if there is any button deck
        if (window.config.buttons && typeof window.config.buttons === "object") {
            Object.values(window.config.buttons).forEach(btn => {
                if (btn && Array.isArray(btn.commands)) {
                    btn.commands.forEach(cmd => {
                        if (cmd.type && cmd.type.startsWith("twitch_") && cmd.type !== "twitch_command") {
                            const oldCmdType = cmd.type;
                            cmd.type = "twitch_command";
                            migratedAny = true;

                            if (oldCmdType === "twitch_send_message") {
                                cmd.commandType = "send_message";
                            } else if (oldCmdType === "twitch_ban_user") {
                                cmd.commandType = "ban_user";
                            } else if (oldCmdType === "twitch_timeout_user") {
                                cmd.commandType = "timeout_user";
                            } else if (oldCmdType === "twitch_unban_user") {
                                cmd.commandType = "unban_user";
                            } else if (oldCmdType === "twitch_clear_chat") {
                                cmd.commandType = "clear_chat";
                            } else if (oldCmdType === "twitch_shoutout") {
                                cmd.commandType = "shoutout";
                            } else if (oldCmdType === "twitch_announce") {
                                cmd.commandType = "announce";
                            } else if (oldCmdType === "twitch_add_moderator") {
                                cmd.commandType = "add_moderator";
                            } else if (oldCmdType === "twitch_remove_moderator") {
                                cmd.commandType = "remove_moderator";
                            } else if (oldCmdType === "twitch_add_vip") {
                                cmd.commandType = "add_vip";
                            } else if (oldCmdType === "twitch_remove_vip") {
                                cmd.commandType = "remove_vip";
                            } else if (oldCmdType === "twitch_slow_mode") {
                                cmd.commandType = "slow_mode";
                            } else if (oldCmdType === "twitch_follower_only") {
                                cmd.commandType = "follower_only";
                            } else if (oldCmdType === "twitch_subscriber_only") {
                                cmd.commandType = "subscriber_only";
                            } else if (oldCmdType === "twitch_emote_only") {
                                cmd.commandType = "emote_only";
                            } else if (oldCmdType === "twitch_update_stream") {
                                cmd.commandType = "update_stream";
                            }
                            logMsg(`[Twitch API] Migrated legacy button command type "${oldCmdType}" to "twitch_command" (commandType: "${cmd.commandType}")`);
                        }
                    });
                }
            });
        }

        if (migratedAny) {
            logMsg("[Twitch API] Saved configuration automatically migrated to unified Twitch Event/Command schema.");
            if (window.saveConfig) window.saveConfig();
        }
    }

    // Register Legacy Outbound Send Message Command
    window.TheaterController.registerCommand("twitch_send_message", async (inputs, matches, payload) => {
        const textTemplate = inputs.message || "";
        if (!textTemplate) return;

        const resolvedMessage = window.TheaterController.replaceVariables ?
            window.TheaterController.replaceVariables(textTemplate, matches, payload) :
            replaceTemplateVariables(textTemplate, matches, payload);
        sendTwitchMessage(resolvedMessage);
    }, {
        label: "Twitch: Send Chat Message",
        fields: [
            {
                id: "message",
                label: "Message Text (supports {username}, wildcards {1}, or custom event data)",
                type: "text",
                default: "Thanks for the support {username}!"
            }
        ]
    }, MODULE_ID);

    // Register Unified Outbound Action/Command
    window.TheaterController.registerCommand("twitch_command", async (inputs, matches, payload) => {
        const commandType = inputs.commandType || "send_message";
        const resolve = (txt) => {
            if (!txt) return "";
            return window.TheaterController.replaceVariables ?
                window.TheaterController.replaceVariables(txt, matches, payload) :
                replaceTemplateVariables(txt, matches, payload);
        };

        if (commandType === 'send_message') {
            const textTemplate = inputs.message || "";
            if (textTemplate) {
                sendTwitchMessage(resolve(textTemplate));
            }
        } else if (commandType === 'ban_user') {
            const target = resolve(inputs.targetUser);
            const reason = resolve(inputs.reason);
            if (target) {
                banTwitchUser(target, 0, reason);
            }
        } else if (commandType === 'timeout_user') {
            const target = resolve(inputs.targetUser);
            const duration = inputs.duration !== undefined ? parseInt(inputs.duration, 10) : 600;
            const reason = resolve(inputs.reason);
            if (target) {
                banTwitchUser(target, duration, reason);
            }
        } else if (commandType === 'unban_user') {
            const target = resolve(inputs.targetUser);
            if (target) {
                unbanTwitchUser(target);
            }
        } else if (commandType === 'clear_chat') {
            clearTwitchChat();
        } else if (commandType === 'shoutout') {
            const target = resolve(inputs.targetUser);
            if (target) {
                shoutoutTwitchUser(target);
            }
        } else if (commandType === 'announce') {
            const textTemplate = inputs.message || "";
            if (textTemplate) {
                sendTwitchAnnouncement(resolve(textTemplate), "primary");
            }
        } else if (commandType === 'add_moderator') {
            const target = resolve(inputs.targetUser);
            if (target) {
                updateTwitchUserRole("add", "moderator", target);
            }
        } else if (commandType === 'remove_moderator') {
            const target = resolve(inputs.targetUser);
            if (target) {
                updateTwitchUserRole("remove", "moderator", target);
            }
        } else if (commandType === 'add_vip') {
            const target = resolve(inputs.targetUser);
            if (target) {
                updateTwitchUserRole("add", "vip", target);
            }
        } else if (commandType === 'remove_vip') {
            const target = resolve(inputs.targetUser);
            if (target) {
                updateTwitchUserRole("remove", "vip", target);
            }
        } else if (commandType === 'slow_mode') {
            const seconds = inputs.seconds !== undefined ? parseInt(inputs.seconds, 10) : 10;
            updateTwitchChatSettings(seconds > 0 ? { slow_mode: true, slow_mode_wait_time: seconds } : { slow_mode: false });
        } else if (commandType === 'follower_only') {
            const minutes = inputs.minutes !== undefined ? parseInt(inputs.minutes, 10) : 10;
            updateTwitchChatSettings(minutes > 0 ? { follower_mode: true, follower_mode_delay: minutes } : { follower_mode: false });
        } else if (commandType === 'subscriber_only') {
            const enabled = inputs.enabled || "on";
            updateTwitchChatSettings({ subscriber_mode: enabled === "on" });
        } else if (commandType === 'emote_only') {
            const enabled = inputs.enabled || "on";
            updateTwitchChatSettings({ emote_mode: enabled === "on" });
        } else if (commandType === 'update_stream') {
            const title = resolve(inputs.title);
            const gameId = resolve(inputs.gameId);
            updateTwitchStreamInfo(title, gameId);
        } else if (commandType === 'raid') {
            const target = resolve(inputs.targetUser);
            if (target) {
                startRaidTwitchUser(target);
            }
        } else if (commandType === 'cancel_raid') {
            cancelRaidTwitch();
        } else if (commandType === 'commercial') {
            const duration = inputs.duration !== undefined ? parseInt(inputs.duration, 10) : 30;
            startTwitchCommercial(duration);
        } else if (commandType === 'stream_marker') {
            const desc = resolve(inputs.description);
            createTwitchStreamMarker(desc);
        } else if (commandType === 'enable_reward') {
            const rewardName = resolve(inputs.rewardName);
            if (rewardName) updateCustomReward(rewardName, true);
        } else if (commandType === 'disable_reward') {
            const rewardName = resolve(inputs.rewardName);
            if (rewardName) updateCustomReward(rewardName, false);
        } else if (commandType === 'guest_star_invite') {
            const guest = resolve(inputs.targetUser);
            if (guest) sendGuestStarInvite(guest);
        } else if (commandType === 'guest_star_cancel_invite') {
            const guest = resolve(inputs.targetUser);
            if (guest) deleteGuestStarInvite(guest);
        } else if (commandType === 'guest_star_assign_slot') {
            const guest = resolve(inputs.targetUser);
            const slot = resolve(inputs.guestStarSlotId) || "1";
            if (guest) assignGuestStarSlot(guest, slot);
        } else if (commandType === 'guest_star_remove_slot') {
            const guest = resolve(inputs.targetUser);
            const slot = resolve(inputs.guestStarSlotId) || "1";
            if (guest) deleteGuestStarSlot(guest, slot);
        } else if (commandType === 'guest_star_slot_settings') {
            const slot = resolve(inputs.guestStarSlotId) || "1";
            const settings = {};
            if (inputs.guestStarMuteAudio !== undefined) settings.is_audio_enabled = inputs.guestStarMuteAudio !== "muted";
            if (inputs.guestStarMuteVideo !== undefined) settings.is_video_enabled = inputs.guestStarMuteVideo !== "muted";
            updateGuestStarSlotSettings(slot, settings);
        }
    }, {
        label: "Twitch: Action / Command",
        fields: [
            {
                id: "commandType",
                label: "Twitch Command Type",
                type: "select",
                options: [
                    { value: "send_message", label: "Send Chat Message" },
                    { value: "ban_user", label: "Ban User" },
                    { value: "timeout_user", label: "Timeout User" },
                    { value: "unban_user", label: "Unban User" },
                    { value: "clear_chat", label: "Clear Chat" },
                    { value: "shoutout", label: "Shoutout User" },
                    { value: "announce", label: "Send Announcement" },
                    { value: "add_moderator", label: "Add Moderator (/mod)" },
                    { value: "remove_moderator", label: "Remove Moderator (/unmod)" },
                    { value: "add_vip", label: "Add VIP (/vip)" },
                    { value: "remove_vip", label: "Remove VIP (/unvip)" },
                    { value: "slow_mode", label: "Set Slow Mode" },
                    { value: "follower_only", label: "Set Follower Only Mode" },
                    { value: "subscriber_only", label: "Set Subscriber Only Mode" },
                    { value: "emote_only", label: "Set Emote Only Mode" },
                    { value: "update_stream", label: "Update Stream Metadata" },
                    { value: "raid", label: "Raid Channel" },
                    { value: "cancel_raid", label: "Cancel Raid" },
                    { value: "commercial", label: "Run Commercial Break" },
                    { value: "stream_marker", label: "Create Stream Marker" },
                    { value: "enable_reward", label: "Enable Channel Point Reward" },
                    { value: "disable_reward", label: "Disable Channel Point Reward" },
                    { value: "guest_star_invite", label: "Guest Star: Send Invite" },
                    { value: "guest_star_cancel_invite", label: "Guest Star: Cancel Invite" },
                    { value: "guest_star_assign_slot", label: "Guest Star: Assign Slot" },
                    { value: "guest_star_remove_slot", label: "Guest Star: Remove from Slot" },
                    { value: "guest_star_slot_settings", label: "Guest Star: Update Slot Settings" }
                ],
                default: "send_message"
            },
            {
                id: "message",
                label: "Message Text (supports {username}, wildcards {1}, or custom event data)",
                type: "text",
                default: "Thanks for the support {username}!",
                style: "grid-column: 1 / -1;"
            },
            {
                id: "targetUser",
                label: "Target Username",
                type: "text",
                default: "{username}"
            },
            {
                id: "reason",
                label: "Reason (optional)",
                type: "text",
                default: "Automated moderation"
            },
            {
                id: "duration",
                label: "Timeout / Commercial Duration (seconds)",
                type: "number",
                default: 600
            },
            {
                id: "seconds",
                label: "Slow duration in seconds (0 to turn off)",
                type: "number",
                default: 10
            },
            {
                id: "minutes",
                label: "Follow duration in minutes (0 to turn off)",
                type: "number",
                default: 10
            },
            {
                id: "enabled",
                label: "Status",
                type: "select",
                options: [
                    { value: "on", label: "Enabled (On)" },
                    { value: "off", label: "Disabled (Off)" }
                ],
                default: "on"
            },
            {
                id: "title",
                label: "Stream Title",
                type: "text",
                default: "",
                style: "grid-column: 1 / -1;"
            },
            {
                id: "gameId",
                label: "Game / Category Name or ID",
                type: "text",
                default: ""
            },
            {
                id: "description",
                label: "Marker Description (optional)",
                type: "text",
                default: "Triggered marker"
            },
            {
                id: "rewardName",
                label: "Reward Name or ID",
                type: "text",
                default: ""
            },
            {
                id: "guestStarSlotId",
                label: "Guest Star Slot ID (1–5)",
                type: "text",
                default: "1"
            },
            {
                id: "guestStarMuteAudio",
                label: "Audio",
                type: "select",
                options: [
                    { value: "live", label: "Live (Unmuted)" },
                    { value: "muted", label: "Muted" }
                ],
                default: "live"
            },
            {
                id: "guestStarMuteVideo",
                label: "Video",
                type: "select",
                options: [
                    { value: "live", label: "Live (Visible)" },
                    { value: "muted", label: "Hidden" }
                ],
                default: "live"
            }
        ]
    }, MODULE_ID);

    // ─── Twitch Autocomplete Suggestion Helper ───────────────────────────────
    const TWITCH_COMMANDS = [
        { cmd: "/timeout", desc: "/timeout <user> [sec] [reason]" },
        { cmd: "/ban", desc: "/ban <user> [reason]" },
        { cmd: "/unban", desc: "/unban <user>" },
        { cmd: "/shoutout", desc: "/shoutout <user>" },
        { cmd: "/announce", desc: "/announce <message>" },
        { cmd: "/clear", desc: "/clear (clears chat)" },
        { cmd: "/me", desc: "/me <message>" },
        { cmd: "/subscribers", desc: "/subscribers (enable sub-only)" },
        { cmd: "/subscribersoff", desc: "/subscribersoff (disable sub-only)" },
        { cmd: "/emotesonly", desc: "/emotesonly (enable emote-only)" },
        { cmd: "/emotesonlyoff", desc: "/emotesonlyoff (disable emote-only)" },
        { cmd: "/slow", desc: "/slow [seconds]" },
        { cmd: "/slowoff", desc: "/slowoff (disable slow)" },
        { cmd: "/mods", desc: "/mods (list moderators)" },
        { cmd: "/vips", desc: "/vips (list VIPs)" }
    ];

    let activeIndex = 0;
    let filteredCommands = [];
    let activeInput = null;

    function injectStyles() {
        const styleId = "twitch-autocomplete-styles";
        if (document.getElementById(styleId)) return;
        const style = document.createElement("style");
        style.id = styleId;
        style.innerHTML = `
            #twitch-autocomplete-menu {
                position: absolute;
                background: rgba(25, 25, 25, 0.98);
                border: 1px solid var(--accent, #007acc);
                border-radius: 6px;
                box-shadow: 0 8px 24px rgba(0, 0, 0, 0.7), 0 0 10px rgba(0, 122, 204, 0.25);
                z-index: 100000;
                max-height: 200px;
                overflow-y: auto;
                font-family: 'Outfit', sans-serif;
                box-sizing: border-box;
                backdrop-filter: blur(8px);
                scrollbar-width: thin;
                scrollbar-color: var(--accent, #007acc) #1a1a1a;
            }
            #twitch-autocomplete-menu::-webkit-scrollbar {
                width: 6px;
            }
            #twitch-autocomplete-menu::-webkit-scrollbar-track {
                background: #1a1a1a;
            }
            #twitch-autocomplete-menu::-webkit-scrollbar-thumb {
                background: var(--accent, #007acc);
                border-radius: 3px;
            }
            .twitch-autocomplete-item {
                padding: 8px 12px;
                cursor: pointer;
                display: flex;
                flex-direction: column;
                border-bottom: 1px solid #333;
                transition: all 0.15s ease;
                box-sizing: border-box;
            }
            .twitch-autocomplete-item:last-child {
                border-bottom: none;
            }
            .twitch-autocomplete-item.active {
                background: var(--accent, #007acc);
            }
            .twitch-autocomplete-item:hover {
                background: rgba(255, 255, 255, 0.05);
            }
            .twitch-autocomplete-item.active:hover {
                background: var(--accent, #007acc);
            }
            .twitch-autocomplete-cmd {
                font-weight: bold;
                color: #ffffff;
                font-size: 0.95em;
            }
            .twitch-autocomplete-desc {
                font-size: 0.8em;
                color: #aaa;
                margin-top: 2px;
            }
            .twitch-autocomplete-item.active .twitch-autocomplete-desc {
                color: #e0e0e0;
            }
        `;
        document.head.appendChild(style);
    }

    function removeStyles() {
        const style = document.getElementById("twitch-autocomplete-styles");
        if (style) style.remove();
    }

    function showMenu(input, commands) {
        activeInput = input;
        filteredCommands = commands;
        activeIndex = 0;

        let menu = document.getElementById("twitch-autocomplete-menu");
        if (!menu) {
            menu = document.createElement("div");
            menu.id = "twitch-autocomplete-menu";
            document.body.appendChild(menu);
        }

        renderMenuContent(menu);
        positionMenu(menu, input);
    }

    function hideMenu() {
        const menu = document.getElementById("twitch-autocomplete-menu");
        if (menu) menu.remove();
        activeInput = null;
        filteredCommands = [];
    }

    function positionMenu(menu, input) {
        const rect = input.getBoundingClientRect();
        menu.style.top = (window.scrollY + rect.bottom + 4) + "px";
        menu.style.left = (window.scrollX + rect.left) + "px";
        menu.style.width = rect.width + "px";
    }

    function renderMenuContent(menu) {
        menu.innerHTML = "";
        filteredCommands.forEach((item, index) => {
            const div = document.createElement("div");
            div.className = `twitch-autocomplete-item ${index === activeIndex ? 'active' : ''}`;
            div.innerHTML = `
                <span class="twitch-autocomplete-cmd">${item.cmd}</span>
                <span class="twitch-autocomplete-desc">${item.desc}</span>
            `;
            div.onclick = (e) => {
                e.stopPropagation();
                selectCommand(item.cmd);
            };
            menu.appendChild(div);
        });
        
        const activeItem = menu.children[activeIndex];
        if (activeItem) {
            activeItem.scrollIntoView({ block: "nearest" });
        }
    }

    function selectCommand(cmd) {
        if (!activeInput) return;
        activeInput.value = cmd + " ";
        activeInput.dispatchEvent(new Event('input', { bubbles: true }));
        activeInput.dispatchEvent(new Event('change', { bubbles: true }));
        activeInput.focus();
        hideMenu();
    }

    function handleInput(e) {
        const target = e.target;
        if (!target || !target.classList.contains('cmd-custom-message')) {
            hideMenu();
            return;
        }

        const commandRow = target.closest('.command-row');
        if (!commandRow) {
            hideMenu();
            return;
        }
        
        const typeSelect = commandRow.querySelector('.cmd-type');
        if (!typeSelect || (typeSelect.value !== 'twitch_send_message' && typeSelect.value !== 'twitch_command')) {
            hideMenu();
            return;
        }

        if (typeSelect.value === 'twitch_command') {
            const commandTypeSelect = commandRow.querySelector('.cmd-custom-commandType');
            if (!commandTypeSelect || commandTypeSelect.value !== 'send_message') {
                hideMenu();
                return;
            }
        }

        updateBanWarning(target);

        const value = target.value;
        if (value.startsWith("/")) {
            const query = value.toLowerCase();
            const matches = TWITCH_COMMANDS.filter(item => 
                item.cmd.toLowerCase().startsWith(query)
            );
            if (matches.length > 0) {
                showMenu(target, matches);
            } else {
                hideMenu();
            }
        } else {
            hideMenu();
        }
    }

    function updateBanWarning(input) {
        if (!input) return;
        const parent = input.parentElement;
        if (!parent) return;

        const val = (input.value || "").trim().toLowerCase();
        const hasWarning = val.startsWith("/ban") || val.startsWith("/timeout");
        
        let warningEl = parent.querySelector(".twitch-ban-warning");
        
        if (hasWarning) {
            if (!warningEl) {
                warningEl = document.createElement("div");
                warningEl.className = "twitch-ban-warning";
                warningEl.style.cssText = `
                    color: #ffb74d;
                    font-size: 0.82em;
                    margin-top: 6px;
                    display: flex;
                    align-items: flex-start;
                    gap: 6px;
                    background: rgba(255, 183, 77, 0.08);
                    border: 1px solid rgba(255, 183, 77, 0.25);
                    padding: 8px 10px;
                    border-radius: 4px;
                    box-sizing: border-box;
                    line-height: 1.4;
                `;
                warningEl.innerHTML = `
                    <span style="font-size: 1.1em;">⚠️</span>
                    <span><strong>Warning:</strong> Twitch does not tolerate automated bans or timeouts. Triggering moderation actions automatically on events can get your bot/account suspended.</span>
                `;
                parent.appendChild(warningEl);
            }
        } else {
            if (warningEl) {
                warningEl.remove();
            }
        }
    }

    let isUpdatingDOM = false;
    function runWithoutObserver(fn) {
        if (isUpdatingDOM) {
            fn();
            return;
        }
        const targetNode = document.getElementById('triggers-container');
        const active = (triggerObserver && targetNode);
        if (active) {
            triggerObserver.disconnect();
        }
        isUpdatingDOM = true;
        try {
            fn();
        } finally {
            isUpdatingDOM = false;
            if (active && targetNode) {
                triggerObserver.observe(targetNode, { childList: true, subtree: true });
            }
        }
    }

    function handleDocumentChange(e) {
        if (e.target) {
            if (e.target.classList.contains('t-custom-eventType')) {
                const card = e.target.closest('.trigger-card');
                if (card) {
                    runWithoutObserver(() => updateTriggerFieldsVisibility(card));
                }
            }
            if (e.target.classList.contains('cmd-custom-commandType')) {
                const row = e.target.closest('.command-row');
                if (row) {
                    runWithoutObserver(() => updateCommandFieldsVisibility(row));
                }
            }
            if (e.target.classList.contains('t-trigger-type') || e.target.classList.contains('cmd-type')) {
                setTimeout(() => {
                    runWithoutObserver(updateAllTwitchFieldsVisibility);
                }, 50);
            }
        }
    }

    function startObservingTriggers() {
        const targetNode = document.getElementById('triggers-container');
        if (!targetNode) return;
        
        runWithoutObserver(() => {
            scanAllInputs();
            updateAllTwitchFieldsVisibility();
        });

        triggerObserver = new MutationObserver(() => {
            runWithoutObserver(() => {
                scanAllInputs();
                updateAllTwitchFieldsVisibility();
            });
        });

        triggerObserver.observe(targetNode, { childList: true, subtree: true });
        document.addEventListener('change', handleDocumentChange);
    }

    function stopObservingTriggers() {
        if (triggerObserver) {
            triggerObserver.disconnect();
            triggerObserver = null;
        }
        document.removeEventListener('change', handleDocumentChange);
    }

    function scanAllInputs() {
        const inputs = document.querySelectorAll('.cmd-custom-message');
        inputs.forEach(input => {
            const commandRow = input.closest('.command-row');
            if (commandRow) {
                const typeSelect = commandRow.querySelector('.cmd-type');
                if (typeSelect && (typeSelect.value === 'twitch_send_message' || typeSelect.value === 'twitch_command')) {
                    if (typeSelect.value === 'twitch_command') {
                        const commandTypeSelect = commandRow.querySelector('.cmd-custom-commandType');
                        if (commandTypeSelect && commandTypeSelect.value === 'send_message') {
                            updateBanWarning(input);
                        }
                    } else {
                        updateBanWarning(input);
                    }
                }
            }
        });
    }

    function handleKeyDown(e) {
        if (!activeInput) return;
        const menu = document.getElementById("twitch-autocomplete-menu");
        if (!menu) return;

        if (e.key === "ArrowDown") {
            e.preventDefault();
            e.stopPropagation();
            activeIndex = (activeIndex + 1) % filteredCommands.length;
            renderMenuContent(menu);
        } else if (e.key === "ArrowUp") {
            e.preventDefault();
            e.stopPropagation();
            activeIndex = (activeIndex - 1 + filteredCommands.length) % filteredCommands.length;
            renderMenuContent(menu);
        } else if (e.key === "Enter" || e.key === "Tab") {
            e.preventDefault();
            e.stopPropagation();
            const selected = filteredCommands[activeIndex];
            if (selected) {
                selectCommand(selected.cmd);
            }
        } else if (e.key === "Escape") {
            e.preventDefault();
            e.stopPropagation();
            hideMenu();
        }
    }

    function handleClick(e) {
        const menu = document.getElementById("twitch-autocomplete-menu");
        if (menu && !menu.contains(e.target) && e.target !== activeInput) {
            hideMenu();
        }
    }

    function updateTriggerFieldsVisibility(card) {
        const typeSelect = card.querySelector('.t-trigger-type');
        if (!typeSelect || typeSelect.value !== 'twitch_event') return;

        const eventTypeSelect = card.querySelector('.t-custom-eventType');
        if (!eventTypeSelect) return;

        const eventType = eventTypeSelect.value;

        const fields = {
            messageContains: eventType === 'message' || eventType === 'reward_redeemed' || eventType === 'power_up_redeemed',
            exactMatch: eventType === 'message' || eventType === 'reward_redeemed' || eventType === 'power_up_redeemed',
            isCommand: eventType === 'message',
            minMonths: eventType === 'subscription',
            minGiftCount: eventType === 'gifted_subscription',
            reasonContains: eventType === 'user_banned',
            minBits: eventType === 'cheer',
            rewardId: eventType === 'reward_redeemed' || eventType === 'power_up_redeemed',
            guestState: eventType === 'guest_star_guest_update'
        };

        for (const [fieldId, shouldShow] of Object.entries(fields)) {
            const el = card.querySelector(`.t-custom-${fieldId}`);
            if (el) {
                const parent = el.closest('div');
                if (parent) {
                    parent.style.display = shouldShow ? 'block' : 'none';
                }
            }
        }

        const rewardSelect = card.querySelector('select.t-custom-rewardId');
        if (rewardSelect) {
            populateRewardDropdown(rewardSelect, eventType);
        }
    }

    function updateCommandFieldsVisibility(row) {
        const typeSelect = row.querySelector('.cmd-type');
        if (!typeSelect || typeSelect.value !== 'twitch_command') return;

        const commandTypeSelect = row.querySelector('.cmd-custom-commandType');
        if (!commandTypeSelect) return;

        const commandType = commandTypeSelect.value;

        const guestStarUserCommands = ['guest_star_invite', 'guest_star_cancel_invite', 'guest_star_assign_slot', 'guest_star_remove_slot'];
        const guestStarSlotCommands = ['guest_star_assign_slot', 'guest_star_remove_slot', 'guest_star_slot_settings'];

        const fields = {
            message: commandType === 'send_message' || commandType === 'announce',
            targetUser: ['ban_user', 'timeout_user', 'unban_user', 'add_moderator', 'remove_moderator', 'add_vip', 'remove_vip', 'shoutout', 'raid', ...guestStarUserCommands].includes(commandType),
            reason: ['ban_user', 'timeout_user'].includes(commandType),
            duration: commandType === 'timeout_user' || commandType === 'commercial',
            seconds: commandType === 'slow_mode',
            minutes: commandType === 'follower_only',
            enabled: ['subscriber_only', 'emote_only'].includes(commandType),
            title: commandType === 'update_stream',
            gameId: commandType === 'update_stream',
            description: commandType === 'stream_marker',
            rewardName: ['enable_reward', 'disable_reward'].includes(commandType),
            guestStarSlotId: guestStarSlotCommands.includes(commandType),
            guestStarMuteAudio: commandType === 'guest_star_slot_settings',
            guestStarMuteVideo: commandType === 'guest_star_slot_settings'
        };

        for (const [fieldId, shouldShow] of Object.entries(fields)) {
            const el = row.querySelector(`.cmd-custom-${fieldId}`);
            if (el) {
                const parent = el.closest('div');
                if (parent) {
                    parent.style.display = shouldShow ? 'block' : 'none';
                }
            }
        }
    }

    function updateAllTwitchFieldsVisibility() {
        document.querySelectorAll('.trigger-card').forEach(card => {
            updateTriggerFieldsVisibility(card);
            card.querySelectorAll('.command-row').forEach(row => {
                updateCommandFieldsVisibility(row);
            });
        });
    }

    // Register Custom Unified Trigger
    window.TheaterController.registerTrigger("twitch_event", 
        (t, eventData) => {
            const selectedEventType = t.eventType || "message";
            if (selectedEventType !== eventData.eventType) return false;

            if (selectedEventType === "message") {
                const msg = (eventData.message || "").trim();
                if (t.messageContains) {
                    const sub = t.messageContains.trim().toLowerCase();
                    if (!msg.toLowerCase().includes(sub)) return false;
                }
                if (t.exactMatch) {
                    const exact = t.exactMatch.trim().toLowerCase();
                    if (msg.toLowerCase() !== exact) return false;
                }
                if (t.isCommand) {
                    const cmd = t.isCommand.trim().toLowerCase();
                    if (!msg.toLowerCase().startsWith(cmd)) return false;
                }
            } else if (selectedEventType === "subscription") {
                const months = parseInt(eventData.months || 1, 10);
                const minMonths = parseInt(t.minMonths || 1, 10);
                if (months < minMonths) return false;
            } else if (selectedEventType === "gifted_subscription") {
                const count = parseInt(eventData.giftCount || 1, 10);
                const minCount = parseInt(t.minGiftCount || 1, 10);
                if (count < minCount) return false;
            } else if (selectedEventType === "user_banned") {
                if (t.reasonContains) {
                    const reason = (eventData.reason || "").trim().toLowerCase();
                    const match = t.reasonContains.trim().toLowerCase();
                    if (!reason.includes(match)) return false;
                }
            } else if (selectedEventType === "cheer") {
                const bits = parseInt(eventData.bits || 0, 10);
                const minBits = parseInt(t.minBits || 1, 10);
                if (bits < minBits) return false;
            } else if (selectedEventType === "reward_redeemed") {
                if (t.rewardId) {
                    const filterVal = t.rewardId.trim().toLowerCase();
                    const gotId = (eventData.reward_id || "").trim().toLowerCase();
                    const gotTitle = (eventData.reward_title || "").trim().toLowerCase();
                    if (gotId !== filterVal && gotTitle !== filterVal) {
                        return false;
                    }
                }
                const msg = (eventData.message || "").trim();
                if (t.messageContains && t.messageContains.trim()) {
                    const sub = t.messageContains.trim().toLowerCase();
                    if (!msg.toLowerCase().includes(sub)) return false;
                }
                if (t.exactMatch && t.exactMatch.trim()) {
                    const exact = t.exactMatch.trim().toLowerCase();
                    if (msg.toLowerCase() !== exact) return false;
                }
                if (t.isCommand && t.isCommand.trim()) {
                    const cmd = t.isCommand.trim().toLowerCase();
                    if (!msg.toLowerCase().startsWith(cmd)) return false;
                }
            } else if (selectedEventType === "power_up_redeemed") {
                if (t.rewardId) {
                    const filterVal = t.rewardId.trim().toLowerCase();
                    const gotId = (eventData.rewardId || "").trim().toLowerCase();
                    const gotName = (eventData.power_up_name || "").trim().toLowerCase();
                    if (gotId !== filterVal && gotName !== filterVal) {
                        return false;
                    }
                }
                const msg = (eventData.message || "").trim();
                if (t.messageContains && t.messageContains.trim()) {
                    const sub = t.messageContains.trim().toLowerCase();
                    if (!msg.toLowerCase().includes(sub)) return false;
                }
                if (t.exactMatch && t.exactMatch.trim()) {
                    const exact = t.exactMatch.trim().toLowerCase();
                    if (msg.toLowerCase() !== exact) return false;
                }
                if (t.isCommand && t.isCommand.trim()) {
                    const cmd = t.isCommand.trim().toLowerCase();
                    if (!msg.toLowerCase().startsWith(cmd)) return false;
                }
            } else if (selectedEventType === "guest_star_guest_update") {
                if (t.guestState && t.guestState !== "") {
                    const state = (eventData.guestState || "").toLowerCase();
                    if (state !== t.guestState.toLowerCase()) return false;
                }
            }
            return true;
        },
        {
            label: "Twitch: Event Received",
            fields: [
                {
                    id: "eventType",
                    label: "Twitch Event Type",
                    type: "select",
                    options: [
                        { value: "message", label: "Chat Message Sent" },
                        { value: "subscription", label: "New / Re-Subscription" },
                        { value: "gifted_subscription", label: "Gifted Subscription" },
                        { value: "cheer", label: "Bits Cheer" },
                        { value: "reward_redeemed", label: "Channel Points Redeem" },
                        { value: "power_up_redeemed", label: "Bits Power-up Redeem" },
                        { value: "host", label: "Channel Hosted / Raided" },
                        { value: "user_banned", label: "User Banned" },
                        { value: "user_timeout", label: "User Timed Out" },
                        { value: "message_deleted", label: "Message Deleted" },
                        { value: "chat_cleared", label: "Chat Cleared" },
                        { value: "guest_star_guest_update", label: "Guest Star: Guest Status Changed" }
                    ],
                    default: "message"
                },
                {
                    id: "messageContains",
                    label: "Message Contains (optional - only for rewards/power-ups with text input)",
                    type: "text",
                    default: "",
                    flexBasis: "100%"
                },
                {
                    id: "exactMatch",
                    label: "Exact Match (optional - only for rewards/power-ups with text input)",
                    type: "text",
                    default: "",
                    flexBasis: "100%"
                },
                {
                    id: "isCommand",
                    label: "Starts With Command (optional, e.g. !play)",
                    type: "text",
                    default: "",
                    flexBasis: "100%"
                },
                {
                    id: "minMonths",
                    label: "Minimum Months",
                    type: "number",
                    default: 1
                },
                {
                    id: "minGiftCount",
                    label: "Minimum Gifted Count",
                    type: "number",
                    default: 1
                },
                {
                    id: "minBits",
                    label: "Minimum Bits",
                    type: "number",
                    default: 1
                },
                {
                    id: "rewardId",
                    label: "Specific Reward / Power-up",
                    type: "select",
                    options: [
                        { value: "", label: "Any Reward/Power-up" }
                    ],
                    default: ""
                },
                {
                    id: "reasonContains",
                    label: "Reason Contains (optional)",
                    type: "text",
                    default: ""
                },
                {
                    id: "guestState",
                    label: "Guest State Filter (leave empty for any)",
                    type: "select",
                    options: [
                        { value: "", label: "Any State" },
                        { value: "invited", label: "Invited" },
                        { value: "accepted", label: "Accepted" },
                        { value: "ready", label: "Ready" },
                        { value: "backstage", label: "Backstage" },
                        { value: "live", label: "Live" },
                        { value: "removed", label: "Removed" }
                    ],
                    default: ""
                }
            ]
        },
        MODULE_ID
    );

    // Register Context Providers for Twitch API
    if (window.TheaterController.registerContextProvider) {
        window.TheaterController.registerContextProvider("twitch_user_info", async (inputs, payload) => {
            const resolve = (txt) => {
                return window.TheaterController.replaceVariables ?
                    window.TheaterController.replaceVariables(txt, [], payload) :
                    replaceTemplateVariables(txt, [], payload);
            };
            const username = resolve(inputs.username || "{username}");
            if (!username) throw new Error("No username specified");

            const token = await getValidToken();
            if (!token) throw new Error("Missing Twitch token");

            const response = await fetch(`https://api.twitch.tv/helix/users?login=${encodeURIComponent(username)}`, {
                method: 'GET',
                headers: {
                    'Client-Id': CLIENT_ID,
                    'Authorization': `Bearer ${token}`
                }
            });
            if (!response.ok) {
                const text = await response.text();
                throw new Error(`Helix error: ${response.status} - ${text}`);
            }
            const data = await response.json();
            return { twitch_user: data };
        }, {
            label: "Twitch: Get User Info",
            fields: [
                { id: "username", label: "Username to check", type: "text", default: "{username}" }
            ]
        }, MODULE_ID);

        window.TheaterController.registerContextProvider("twitch_channel_info", async (inputs, payload) => {
            const resolve = (txt) => {
                return window.TheaterController.replaceVariables ?
                    window.TheaterController.replaceVariables(txt, [], payload) :
                    replaceTemplateVariables(txt, [], payload);
            };
            const username = resolve(inputs.username || "{username}");
            if (!username) throw new Error("No username specified");

            const token = await getValidToken();
            if (!token) throw new Error("Missing Twitch token");

            const targetUserId = await resolveUserId(username);
            if (!targetUserId) throw new Error(`Could not resolve target user ID for "${username}"`);

            const response = await fetch(`https://api.twitch.tv/helix/channels?broadcaster_id=${targetUserId}`, {
                method: 'GET',
                headers: {
                    'Client-Id': CLIENT_ID,
                    'Authorization': `Bearer ${token}`
                }
            });
            if (!response.ok) {
                const text = await response.text();
                throw new Error(`Helix error: ${response.status} - ${text}`);
            }
            const data = await response.json();
            return { twitch_channel: data };
        }, {
            label: "Twitch: Get Channel Info",
            fields: [
                { id: "username", label: "Broadcaster username to check", type: "text", default: "{username}" }
            ]
        }, MODULE_ID);

        window.TheaterController.registerContextProvider("guest_star_session_info", async (inputs, payload) => {
            const session = await fetchGuestStarSession();
            if (!session) throw new Error("No active Guest Star session found.");
            return { guest_star_session: session };
        }, {
            label: "Twitch: Get Active Guest Star Session",
            fields: []
        }, MODULE_ID);
    }

    window.TheaterController.registerModule(MODULE_ID, MODULE_DEFINITION);
})();
