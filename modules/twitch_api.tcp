        logMsg(`[Twitch API] Sending Guest Star invite to "${guestUsername}"...`);
        try {
            const response = await fetch(`https://api.twitch.tv/helix/guest_star/invites?broadcaster_id=${broadcasterId}&moderator_id=${broadcasterId}&session_id=${currentConfig.guest_star_session_id || ""}&guest_id=${guestId}`, {
                method: 'POST',
                headers: { 'Client-Id': CLIENT_ID, 'Authorization': `Bearer ${token}` }
