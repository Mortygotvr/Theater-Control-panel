// @theater-tcp-module
(function() {
    const MODULE_ID = "twitch_api";
    let currentConfig = {};
    let triggerObserver = null;

    // Polyfill window.saveConfig if it is missing in the control panel
    if (!window.saveConfig) {
        window.saveConfig = function() {
            if (window.config) {
                localStorage.setItem("obs_bridge_config", JSON.stringify(window.config));
            }
        };
    }

    // Hardcoded Client Credentials and Google Apps Script Proxy URL
    const CLIENT_ID = "8di1qtifccgzrs1jvb6t6ddo8z9crv";
    const REDIRECT_URI = "http://localhost:52246/";
    const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzQx7bjEcYCwviBjFi5USE3q0-QfHNrcqrj0mJVgR38xVb-ogvL8BIIdthumOw7NaRc8A/exec";

    const MODULE_DEFINITION = {
        name: "Twitch API",
        description: "Sends and receives Twitch messages and moderation actions using secure OAuth flow via private Google Apps Script and background token refresh.",
        configFields: [
            {
                id: "broadcaster_id",
                label: "Your Twitch Broadcaster Username (e.g. mortygotvr) <button class='btn-green' onclick='window.TheaterController.modules.twitch_api.definition.authorizeApp()' style='margin-left: 10px; font-size: 0.85em; padding: 3px 8px; cursor: pointer; display: inline-block; vertical-align: middle; border-radius: 4px; border: none;'>🔗 Connect Account</button>",
                type: "text",
                default: ""
            }
        ],
        variablePresets: [
            {
                id: "twitch-chat",
                label: "Twitch: Chat Message",
                optgroupLabel: "Twitch Presets",
                samplePayload: {
                    "username": "chatter_box",
                    "message": "Hello from Twitch chat! PogChamp",
                    "customData": {
                        "username": "chatter_box",
                        "message": "Hello from Twitch chat! PogChamp",
                        "subscriber": true,
                        "mod": false,
                        "vip": true,
                        "color": "#ff0000"
                    }
                }
            },
            {
                id: "twitch-sub",
                label: "Twitch: Subscription",
                optgroupLabel: "Twitch Presets",
                samplePayload: {
                    "username": "twitch_subscriber",
                    "message": "I love the stream!",
                    "customData": {
                        "username": "twitch_subscriber",
                        "message": "I love the stream!",
                        "months": 12,
                        "tier": "1000"
                    }
                }
            },
            {
                id: "twitch-redeem",
                label: "Twitch: Channel Points Redeem",
                optgroupLabel: "Twitch Presets",
                samplePayload: {
                    "username": "points_redeemer",
                    "message": "Play sound effect",
                    "customData": {
                        "username": "points_redeemer",
                        "message": "Play sound effect",
                        "reward_title": "Play Sound",
                        "reward_cost": 500,
                        "reward_id": "uuid-xyz-123"
                    }
                }
            },
            {
                id: "twitch-cheer",
                label: "Twitch: Bits Cheer",
                optgroupLabel: "Twitch Presets",
                samplePayload: {
                    "username": "bit_cheerer",
                    "message": "Here are 100 bits!",
                    "customData": {
                        "username": "bit_cheerer",
                        "message": "Here are 100 bits!",
                        "bits": 100
                    }
                }
            },
            {
                id: "twitch-power-up",
                label: "Twitch: Bits Power-up Redeem",
                optgroupLabel: "Twitch Presets",
                samplePayload: {
                    "username": "powerup_redeemer",
                    "message": "Send a cool effect!",
                    "customData": {
                        "username": "powerup_redeemer",
                        "message": "Send a cool effect!",
                        "power_up_id": "message_effect",
                        "power_up_name": "Message Effect",
                        "bits": 100,
                        "id": "uuid-xyz-456"
                    }
                }
            },
            {
                id: "twitch-get-user-info",
                label: "Twitch: Get User Info Details",
                optgroupLabel: "Get Command Presets",
                samplePayload: {
                    "twitch_user": {
                        "data": [
                            {
                                "id": "141211776",
                                "login": "twitchdev",
                                "display_name": "TwitchDev",
                                "type": "",
                                "broadcaster_type": "partner",
                                "description": "Supporting third-party developers building Twitch integrations.",
                                "profile_image_url": "https://static-cdn.jtvnw.net/jtv_user_pictures/8a632a5c-f0bc-47e1-8840-77a83d47d4e5-profile_image-300x300.png",
                                "offline_image_url": "https://static-cdn.jtvnw.net/jtv_user_pictures/3f51ae85-ec4a-464e-a9a3-a7c34f828a2a-channel_offline_image-1920x1080.png",
                                "view_count": 5917,
                                "created_at": "2016-12-14T20:32:19Z"
                            }
                        ]
                    }
                }
            },
            {
                id: "twitch-get-channel-info",
                label: "Twitch: Get Channel Info Details",
                optgroupLabel: "Get Command Presets",
                samplePayload: {
                    "twitch_channel": {
                        "data": [
                            {
                                "broadcaster_id": "141211776",
                                "broadcaster_login": "twitchdev",
                                "broadcaster_name": "TwitchDev",
                                "broadcaster_language": "en",
                                "game_id": "509658",
                                "game_name": "Just Chatting",
                                "title": "Talk Show: Let's build Twitch integrations!",
                                "delay": 0,
                                "tags": [
                                    "Developer",
                                    "Programming",
                                    "English"
                                ],
                                "content_classification_labels": [
                                    "DrugsIntoxication"
                                ],
                                "is_branded_content": false
                            }
                        ]
                    }
                }
            }
        ],
        onLoad(moduleConfig) {
            logMsg("[Twitch API] Module loaded successfully.");
            currentConfig = moduleConfig;
            
            // Seed hardcoded credentials and proxy settings
            currentConfig.client_id = CLIENT_ID;
            currentConfig.redirect_uri = REDIRECT_URI;
            currentConfig.google_script_url = GOOGLE_SCRIPT_URL;

            // Auto-migrate settings from old twitch_chat module if twitch_api is unconfigured
            if (!currentConfig.broadcaster_id && window.config && window.config.modules && window.config.modules.twitch_chat) {
                logMsg("[Twitch API] Migrating configuration from legacy twitch_chat module...");
                const legacy = window.config.modules.twitch_chat;
                currentConfig.broadcaster_id = legacy.username || "";
                if (!window.config.modules.twitch_api) window.config.modules.twitch_api = {};
                window.config.modules.twitch_api.broadcaster_id = currentConfig.broadcaster_id;
                if (window.saveConfig) window.saveConfig();
            }

            // Automatically migrate legacy triggers & commands
            migrateOldTriggersAndCommands();

            // Autocomplete Setup
            injectStyles();
            document.addEventListener('input', handleInput);
            document.addEventListener('keydown', handleKeyDown, true);
            document.addEventListener('click', handleClick);

            // Warning Observer Setup
            startObservingTriggers();

            // Auto-exchange if auth_code is present but tokens are not
            if (currentConfig.auth_code && (!currentConfig.access_token || !currentConfig.refresh_token)) {
                logMsg("[Twitch API] Saved Authorization Code detected without tokens. Initiating exchange...");
                setTimeout(() => {
                    MODULE_DEFINITION.exchangeCode();
                }, 1000);
            }

            // Connect to Twitch Chatroom WebSocket
            initChatConnection();

            // Connect to Twitch EventSub WebSocket
            initEventSubConnection();

            // Fetch custom rewards and power-ups on startup if broadcaster ID is already resolved
            if (currentConfig.resolved_broadcaster_id) {
                setTimeout(() => {
                    fetchTwitchCustomRewards();
                    fetchTwitchCustomPowerUps();
                }, 2000);
            }
        },
        onUnload() {
            logMsg("[Twitch API] Module unloaded.");
            
            // Clean up Tauri OAuth listener if active
            if (window.twitchAuthUnlisten) {
                try { window.twitchAuthUnlisten(); } catch (e) {}
                window.twitchAuthUnlisten = null;
            }

            // Disconnect Twitch chat WebSocket
            disconnectTwitchChat();

            // Disconnect EventSub WebSocket
            disconnectEventSub();

            // Autocomplete Cleanup
            document.removeEventListener('input', handleInput);
            document.removeEventListener('keydown', handleKeyDown, true);
            document.removeEventListener('click', handleClick);
            hideMenu();
            removeStyles();

            // Warning Observer Cleanup
            stopObservingTriggers();
            document.querySelectorAll(".twitch-ban-warning").forEach(el => el.remove());
        },

        async authorizeApp() {
            try {
                const clientId = CLIENT_ID;
                const redirectUri = REDIRECT_URI;
                const state = Math.random().toString(36).substring(2, 15);
                
                localStorage.setItem("twitch_oauth_state", state);

                const scopes = [
                    "chat:read",
                    "chat:edit",
                    "moderator:manage:banned_users",
                    "moderator:manage:chat_messages",
                    "moderator:manage:shoutouts",
                    "moderator:manage:announcements",
                    "moderator:manage:chat_settings",
                    "channel:manage:moderators",
                    "channel:manage:vips",
                    "channel:manage:broadcast",
                    "channel:manage:redemptions",
                    "channel:read:redemptions",
                    "bits:read",
                    "channel:read:hype_train",
                    "channel:read:polls",
                    "channel:read:predictions",
                    "channel:manage:raids",
                    "channel:edit:commercial",
                    "channel:manage:guest_star",
                    "channel:read:guest_star"
                ].join(" ");

                const authUrl = `https://id.twitch.tv/oauth2/authorize?response_type=code&client_id=${clientId}&redirect_uri=${encodeURIComponent(redirectUri)}&scope=${encodeURIComponent(scopes)}&state=${state}`;
                
                let isLoopback = false;
                let loopbackPort = 52246;
                try {
                    const u = new URL(redirectUri);
                    if ((u.hostname === "127.0.0.1" || u.hostname === "localhost") && u.port) {
                        isLoopback = true;
                        loopbackPort = parseInt(u.port, 10);
                    }
                } catch(e) {}

                if (window.__TAURI__) {
                    if (window.twitchAuthUnlisten) {
                        try { window.twitchAuthUnlisten(); } catch (e) {}
                        window.twitchAuthUnlisten = null;
                    }

                    if (isLoopback) {
                        window.__TAURI__.event.listen('twitch-loopback-code', (event) => {
                            const path = event.payload; // e.g. "/?code=xyz&state=abc"
                            logMsg(`[Twitch API] Automatically captured loopback redirect: ${path}`);
                            try {
                                const urlObj = new URL("http://localhost" + path);
                                const code = urlObj.searchParams.get('code');
                                if (code) {
                                    logMsg(`[Twitch API] Extracted authorization code: ${code}`);
                                    currentConfig.auth_code = code;
                                    
                                    if (window.twitchAuthUnlisten) {
                                        window.twitchAuthUnlisten();
                                        window.twitchAuthUnlisten = null;
                                    }

                                    logMsg(`[Twitch API] Triggering automatic code exchange...`);
                                    setTimeout(() => {
                                        MODULE_DEFINITION.exchangeCode(code);
                                    }, 500);
                                }
                            } catch(err) {
                                logMsg(`[Twitch API Error] Failed to parse loopback redirect: ${err.message}`, true);
                            }
                        }).then(unlistenFn => {
                            window.twitchAuthUnlisten = unlistenFn;
                        });

                        // Start Rust loopback server & open default system browser
                        window.__TAURI__.core.invoke('start_loopback_listener', {
                            port: loopbackPort,
                            eventName: 'twitch-loopback-code'
                        }).catch(err => {
                            logMsg(`[Twitch API Error] Failed to start loopback listener: ${err}`, true);
                        });

                        window.__TAURI__.core.invoke('open_in_browser', { url: authUrl }).catch(err => {
                            logMsg(`[Twitch API Error] Failed to open default browser: ${err}`, true);
                            window.open(authUrl, '_blank');
                        });
                    }
                } else {
                    window.open(authUrl, '_blank');
                }
            } catch (err) {
                logMsg(`[Twitch API Error] Failed to start authorization: ${err.message}`, true);
                alert(`Failed to start authorization flow: ${err.message}`);
            }
        },

        async exchangeCode(code) {
            const authCode = code || currentConfig.auth_code;
            if (!authCode) {
                alert("Please paste the Authorization Code first.");
                return;
            }

            logMsg("[Twitch API] Exchanging authorization code for tokens...");

            try {
                logMsg(`[Twitch API] Routing exchange through Google Apps Script proxy: ${GOOGLE_SCRIPT_URL}`);
                const response = await fetch(GOOGLE_SCRIPT_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'text/plain'
                    },
                    body: JSON.stringify({
                        action: 'exchange',
                        code: authCode,
                        redirect_uri: REDIRECT_URI
                    })
                });

                if (!response.ok) {
                    const errText = await response.text();
                    logMsg(`[Twitch API Error] OAuth exchange failed: ${response.status} ${response.statusText} - ${errText}`, true);
                    alert(`OAuth exchange failed: ${response.statusText}`);
                    return;
                }

                const data = await response.json();
                if (data.error) {
                    logMsg(`[Twitch API Error] Proxy exchange returned error: ${data.error_description || data.error}`, true);
                    alert(`OAuth exchange failed: ${data.error_description || data.error}`);
                    return;
                }

                if (data.access_token && data.refresh_token) {
                    // Update configuration
                    currentConfig.access_token = data.access_token;
                    currentConfig.refresh_token = data.refresh_token;
                    currentConfig.token_expires_at = Date.now() + (data.expires_in * 1000);

                    // Also capture the broadcaster_id from the UI field if the user typed it
                    // (prevents it from being wiped when saveConfig() runs before it's persisted)
                    const broadcasterField = document.querySelector('.mod-field-twitch_api[data-field-id="broadcaster_id"]');
                    if (broadcasterField && broadcasterField.value.trim()) {
                        currentConfig.broadcaster_id = broadcasterField.value.trim();
                    }

                    if (window.config) {
                        if (!window.config.modules) window.config.modules = {};
                        if (!window.config.modules.twitch_api) window.config.modules.twitch_api = {};
                        
                        window.config.modules.twitch_api.auth_code = authCode;
                        window.config.modules.twitch_api.access_token = data.access_token;
                        window.config.modules.twitch_api.refresh_token = data.refresh_token;
                        window.config.modules.twitch_api.token_expires_at = currentConfig.token_expires_at;
                        // Persist broadcaster_id so it survives config save
                        if (currentConfig.broadcaster_id) {
                            window.config.modules.twitch_api.broadcaster_id = currentConfig.broadcaster_id;
                        }
                        if (window.saveConfig) window.saveConfig();
                    }

                    logMsg("[Twitch API] Tokens successfully generated and saved! Setup is complete.");
                    alert("OAuth setup successful! Your tokens have been generated and saved.");

                    // Resolve broadcaster ID via Helix API
                    // Note: resolveBroadcasterId() internally handles initEventSubConnection()
                    // and fetchTwitchCustomRewards/PowerUps after resolution.
                    await resolveBroadcasterId();

                    // Connect to Twitch chat (EventSub is handled inside resolveBroadcasterId)
                    initChatConnection();
                } else {
                    logMsg("[Twitch API Error] OAuth exchange response did not contain tokens.", true);
                }
            } catch (err) {
                logMsg(`[Twitch API Error] Network error during OAuth exchange: ${err.message}`, true);
                alert(`Network error during OAuth exchange: ${err.message}`);
            }
        }
    };

    // ─── Token Verification & Refresh Helper ──────────────────────────────────
    async function getValidToken() {
        let token = (currentConfig.access_token || "").trim();
        const expiresAt = currentConfig.token_expires_at || 0;
        
        if (!token || Date.now() >= (expiresAt - 60000)) {
            const refreshed = await refreshAccessToken();
            if (!refreshed) {
                logMsg("[Twitch API Error] OAuth token refresh failed. Please authorize again.", true);
                return null;
            }
            token = currentConfig.access_token;
        }
        return token;
    }

    async function refreshAccessToken() {
        const refreshToken = (currentConfig.refresh_token || "").trim();
        if (!refreshToken) {
            logMsg("[Twitch API Error] Cannot refresh token: Missing Refresh Token.", true);
            return false;
        }

        logMsg("[Twitch API] Access token expired or missing. Refreshing tokens...");

        try {
            logMsg(`[Twitch API] Routing refresh through Google Apps Script proxy: ${GOOGLE_SCRIPT_URL}`);
            const response = await fetch(GOOGLE_SCRIPT_URL, {
                method: 'POST',
                headers: {
                    'Content-Type': 'text/plain'
                },
                body: JSON.stringify({
                    action: 'refresh',
                    refresh_token: refreshToken
                })
            });

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Twitch API Error] Token refresh failed: ${response.status} ${response.statusText} - ${errText}`, true);
                return false;
            }

            const data = await response.json();
            if (data.error) {
                logMsg(`[Twitch API Error] Proxy refresh returned error: ${data.error_description || data.error}`, true);
                return false;
            }

            if (data.access_token) {
                currentConfig.access_token = data.access_token;
                currentConfig.refresh_token = data.refresh_token || refreshToken;
                currentConfig.token_expires_at = Date.now() + (data.expires_in * 1000);

                if (window.config) {
                    if (!window.config.modules) window.config.modules = {};
                    if (!window.config.modules.twitch_api) window.config.modules.twitch_api = {};
                    
                    window.config.modules.twitch_api.access_token = currentConfig.access_token;
                    window.config.modules.twitch_api.refresh_token = currentConfig.refresh_token;
                    window.config.modules.twitch_api.token_expires_at = currentConfig.token_expires_at;
                    if (window.saveConfig) window.saveConfig();
                }

                logMsg("[Twitch API] Tokens refreshed successfully!");
                return true;
            }
            return false;
        } catch (err) {
            logMsg(`[Twitch API Error] Network error during token refresh: ${err.message}`, true);
            return false;
        }
    }

    // ─── Twitch EventSub WebSocket Client ──────────────────────────────────────
    let eventSubWS = null;
    let eventSubSessionId = null;
    let eventSubReconnectTimer = null;

    async function initEventSubConnection() {
        const broadcasterId = currentConfig.resolved_broadcaster_id;
        if (!broadcasterId) {
            logMsg("[Twitch API] EventSub: Broadcaster ID not resolved yet. Postponing connection.");
            return;
        }

        let token = await getValidToken();
        if (!token) {
            logMsg("[Twitch API Error] Could not connect to EventSub: Missing OAuth access token.", true);
            return;
        }

        connectEventSub(token, broadcasterId);
    }

    function connectEventSub(token, broadcasterId) {
        disconnectEventSub();

        logMsg("[Twitch API] Connecting to Twitch EventSub WebSocket...");

        try {
            eventSubWS = new WebSocket("wss://eventsub.wss.twitch.tv/ws");
        } catch (e) {
            logMsg(`[Twitch API Error] Failed to create EventSub WebSocket: ${e.message}`, true);
            scheduleEventSubReconnect();
            return;
        }

        eventSubWS.onopen = () => {
            logMsg("[Twitch API] Connected to Twitch EventSub WebSocket. Waiting for session parameters...");
        };

        eventSubWS.onmessage = async (event) => {
            try {
                const msg = JSON.parse(event.data);
                const msgType = msg.metadata ? msg.metadata.message_type : "";

                if (msgType === "session_welcome") {
                    eventSubSessionId = msg.payload.session.id;
                    logMsg(`[Twitch API] EventSub Welcome Received! Session ID: ${eventSubSessionId}. Registering subscriptions...`);
                    
                    // Create Custom Reward Redemption Subscription
                    subscribeToEventSub(token, broadcasterId, "channel.channel_points_custom_reward_redemption.add", "1", eventSubSessionId);

                    // Create Bits Use Subscription (for base power-ups and cheers)
                    subscribeToEventSub(token, broadcasterId, "channel.bits.use", "1", eventSubSessionId);

                    // Create Custom Power-up Redemption Subscription
                    subscribeToEventSub(token, broadcasterId, "channel.custom_power_up_redemption.add", "1", eventSubSessionId);

                    // Subscribe to Guest Star session begin/end for automatic session ID capture
                    subscribeToEventSub(token, broadcasterId, "channel.guest_star_session.begin", "beta", eventSubSessionId);
                    subscribeToEventSub(token, broadcasterId, "channel.guest_star_session.end", "beta", eventSubSessionId);

                    // Subscribe to Guest Star guest updates (invite, accept, go live, etc.)
                    subscribeToEventSub(token, broadcasterId, "channel.guest_star_guest_update", "beta", eventSubSessionId);
                } else if (msgType === "notification") {
                    handleEventSubNotification(msg.payload);
                } else if (msgType === "session_keepalive") {
                    // Silent keepalive
                }
            } catch (err) {
                // Ignore parse errors
            }
        };

        eventSubWS.onerror = (err) => {
            logMsg("[Twitch API Error] EventSub WebSocket error occurred.", true);
        };

        eventSubWS.onclose = () => {
            eventSubSessionId = null;
            eventSubWS = null;
            logMsg("[Twitch API] EventSub WebSocket connection closed.");
            scheduleEventSubReconnect();
        };
    }

    function disconnectEventSub() {
        clearTimeout(eventSubReconnectTimer);
        eventSubReconnectTimer = null;
        if (eventSubWS) {
            eventSubWS.onopen = null;
            eventSubWS.onmessage = null;
            eventSubWS.onerror = null;
            eventSubWS.onclose = null;
            if (eventSubWS.readyState === WebSocket.OPEN || eventSubWS.readyState === WebSocket.CONNECTING) {
                try { eventSubWS.close(); } catch(e) {}
            }
            eventSubWS = null;
        }
        eventSubSessionId = null;
    }

    function scheduleEventSubReconnect() {
        clearTimeout(eventSubReconnectTimer);
        eventSubReconnectTimer = setTimeout(() => {
            logMsg("[Twitch API] Reconnecting to EventSub WebSocket...");
            initEventSubConnection();
        }, 15000);
    }

    async function subscribeToEventSub(token, broadcasterId, type, version, sessionId) {
        logMsg(`[Twitch API] Subscribing to EventSub topic "${type}"...`);
        try {
            const response = await fetch("https://api.twitch.tv/helix/eventsub/subscriptions", {
                method: "POST",
                headers: {
                    "Client-Id": CLIENT_ID,
                    "Authorization": `Bearer ${token}`,
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    type: type,
                    version: version,
                    condition: {
                        broadcaster_user_id: broadcasterId
                    },
                    transport: {
                        method: "websocket",
                        session_id: sessionId
                    }
                })
            });

            if (response.ok) {
                logMsg(`[Twitch API] EventSub subscription created successfully for "${type}".`);
            } else {
                const errText = await response.text();
                logMsg(`[Twitch API Error] EventSub subscription failed for "${type}": ${response.status} - ${errText}`, true);
            }
        } catch(e) {
            logMsg(`[Twitch API Error] Error registering EventSub subscription: ${e.message}`, true);
        }
    }

    function handleEventSubNotification(payload) {
        if (!payload || !payload.subscription || !payload.event) return;

        logMsg(`[Twitch EventSub RAW] Notification received for type "${payload.subscription.type}": ` + JSON.stringify(payload.event));

        const subType = payload.subscription.type;
        const event = payload.event;

        if (subType === "channel.channel_points_custom_reward_redemption.add") {
            const redeemer = event.user_name || event.user_login || "Anonymous";
            const userInput = event.user_input || "";
            const reward = event.reward || {};
            const rewardId = reward.id || "";
            const rewardTitle = reward.title || "Custom Reward";
            const rewardCost = reward.cost || 0;

            logMsg(`[Twitch API] Channel Points Redeemed: ${redeemer} redeemed "${rewardTitle}" (${rewardCost} points). Input: "${userInput}"`);

            const triggerPayload = {
                username: redeemer,
                message: userInput,
                customData: {
                    username: redeemer,
                    message: userInput,
                    reward_id: rewardId,
                    reward_title: rewardTitle,
                    reward_cost: rewardCost,
                    id: event.id || ""
                },
                rawEventSub: event
            };

            if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                window.TheaterController.dispatchTrigger("twitch_event", {
                    eventType: "reward_redeemed",
                    username: redeemer,
                    message: userInput,
                    reward_id: rewardId,
                    reward_title: rewardTitle
                }, triggerPayload);
            }
        } else if (subType === "channel.bits.use") {
            const type = event.type || "";
            if (type === "power_up") {
                const redeemer = event.user_name || event.user_login || "Anonymous";
                const bitsUsed = event.bits || 0;
                const powerUp = event.power_up || {};
                const powerUpId = powerUp.type || "";
                
                let powerUpName = "Power-up";
                if (powerUpId === "message_effect") powerUpName = "Message Effect";
                else if (powerUpId === "gigantify_an_emote") powerUpName = "Gigantify an Emote";
                else if (powerUpId === "celebration") powerUpName = "On-Screen Celebration";
                else if (powerUp.name) powerUpName = powerUp.name;

                const message = event.message || "";

                logMsg(`[Twitch API] Bits Power-up Redeemed: ${redeemer} redeemed "${powerUpName}" (${bitsUsed} bits).`);

                const triggerPayload = {
                    username: redeemer,
                    message: message,
                    customData: {
                        username: redeemer,
                        message: message,
                        power_up_id: powerUpId,
                        power_up_name: powerUpName,
                        bits: bitsUsed,
                        id: event.id || ""
                    },
                    rawEventSub: event
                };

                if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                    window.TheaterController.dispatchTrigger("twitch_event", {
                        eventType: "power_up_redeemed",
                        username: redeemer,
                        message: message,
                        rewardId: powerUpId,
                        power_up_name: powerUpName
                    }, triggerPayload);
                }
            }
        } else if (subType === "channel.custom_power_up_redemption.add") {
            const redeemer = event.user_name || event.user_login || "Anonymous";
            const message = event.user_input || "";
            const customPowerUp = event.custom_power_up || {};
            const powerUpId = event.power_up_id || customPowerUp.id || (event.power_up && event.power_up.id) || "";
            const powerUpName = event.power_up_name || customPowerUp.title || customPowerUp.name || (event.power_up && event.power_up.name) || "Custom Power-up";
            const bitsUsed = event.bits_used || event.cost || customPowerUp.bits || customPowerUp.cost || (event.power_up && event.power_up.cost) || 0;

            logMsg(`[Twitch API] Custom Power-up Redeemed: ${redeemer} redeemed "${powerUpName}" (${bitsUsed} bits).`);

            const triggerPayload = {
                username: redeemer,
                message: message,
                customData: {
                    username: redeemer,
                    message: message,
                    power_up_id: powerUpId,
                    power_up_name: powerUpName,
                    bits: bitsUsed,
                    id: event.id || ""
                },
                rawEventSub: event
            };

            if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                window.TheaterController.dispatchTrigger("twitch_event", {
                    eventType: "power_up_redeemed",
                    username: redeemer,
                    message: message,
                    rewardId: powerUpId,
                    power_up_name: powerUpName
                }, triggerPayload);
            }
        } else if (subType === "channel.guest_star_session.begin") {
            const sessionId = event.id || "";
            if (sessionId) {
                currentConfig.guest_star_session_id = sessionId;
                logMsg(`[Twitch API] Guest Star session started. Session ID captured: ${sessionId}`);
            }
        } else if (subType === "channel.guest_star_session.end") {
            logMsg(`[Twitch API] Guest Star session ended. Clearing stored session ID.`);
            currentConfig.guest_star_session_id = null;
        } else if (subType === "channel.guest_star_guest_update") {
            const guest = event.guest || {};
            const guestUsername = guest.user_name || guest.user_login || "Unknown";
            const guestState = guest.state || "";

            logMsg(`[Twitch API] Guest Star guest update: "${guestUsername}" state changed to "${guestState}".`);

            const triggerPayload = {
                username: guestUsername,
                message: guestState,
                customData: {
                    username: guestUsername,
                    user_id: guest.user_id || "",
                    state: guestState,
                    session_id: event.session_id || currentConfig.guest_star_session_id || "",
                    host_audio_enabled: event.host_audio_enabled,
                    host_video_enabled: event.host_video_enabled
                },
                rawEventSub: event
            };

            if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                window.TheaterController.dispatchTrigger("twitch_event", {
                    eventType: "guest_star_guest_update",
                    username: guestUsername,
                    message: guestState,
                    guestState: guestState
                }, triggerPayload);
            }
        }
    }

    // Expose simulator helper globally
    window.twitchEventSubSimulate = function(payload) {
        handleEventSubNotification(payload);
    };

    // ─── Resolve Broadcaster & User IDs ───────────────────────────────────────
    async function resolveBroadcasterId() {
        const username = (currentConfig.broadcaster_id || "").trim().toLowerCase();
        if (!username) return null;
        
        let token = (currentConfig.access_token || "").trim();
        if (!token) return null;
        
        try {
            logMsg(`[Twitch API] Resolving broadcaster user ID for "${username}"...`);
            const response = await fetch(`https://api.twitch.tv/helix/users?login=${username}`, {
                method: 'GET',
                headers: {
                    'Client-Id': CLIENT_ID,
                    'Authorization': `Bearer ${token}`
                }
            });
            
            if (response.ok) {
                const data = await response.json();
                if (data.data && data.data.length > 0) {
                    const user = data.data[0];
                    currentConfig.resolved_broadcaster_id = user.id;
                    currentConfig.resolved_broadcaster_username = username;
                    
                    if (window.config && window.config.modules && window.config.modules.twitch_api) {
                        window.config.modules.twitch_api.resolved_broadcaster_id = user.id;
                        window.config.modules.twitch_api.resolved_broadcaster_username = username;
                        if (window.saveConfig) window.saveConfig();
                    }
                    logMsg(`[Twitch API] Resolved username "${username}" to ID "${user.id}"`);
                    
                    // Trigger EventSub connection once ID is resolved
                    setTimeout(() => {
                        initEventSubConnection();
                    }, 500);

                    // Fetch custom rewards and power-ups once ID is resolved
                    setTimeout(() => {
                        fetchTwitchCustomRewards();
                        fetchTwitchCustomPowerUps();
                    }, 1000);

                    return user.id;
                }
            } else {
                const errText = await response.text();
                logMsg(`[Twitch API Error] Failed to resolve user ID: ${response.status} - ${errText}`, true);
            }
        } catch(e) {
            logMsg(`[Twitch API Error] Network error resolving broadcaster ID: ${e.message}`, true);
        }
        return null;
    }

    let customRewardsList = [];
    let customPowerUpsList = [];

    const BASE_POWER_UPS = [
        { id: "message_effect", title: "Message Effect", cost: "Varies" },
        { id: "gigantify_an_emote", title: "Gigantify an Emote", cost: "Varies" },
        { id: "celebration", title: "On-Screen Celebration", cost: "Varies" }
    ];

    async function fetchTwitchCustomRewards() {
        const broadcasterId = currentConfig.resolved_broadcaster_id;
        if (!broadcasterId) {
            logMsg("[Twitch API] Cannot fetch custom rewards: Broadcaster ID not resolved.");
            return;
        }

        let token = await getValidToken();
        if (!token) {
            logMsg("[Twitch API] Cannot fetch custom rewards: No valid token.");
            return;
        }

        logMsg("[Twitch API] Fetching custom rewards from Twitch Helix API...");
        try {
            const url = `https://api.twitch.tv/helix/channel_points/custom_rewards?broadcaster_id=${broadcasterId}&only_manageable_rewards=false`;
            const response = await fetch(url, {
                method: "GET",
                headers: {
                    "Client-Id": CLIENT_ID,
                    "Authorization": `Bearer ${token}`
                }
            });

            if (response.ok) {
                const result = await response.json();
                if (result.data) {
                    customRewardsList = result.data.map(item => ({
                        id: item.id,
                        title: item.title,
                        cost: item.cost,
                        isEnabled: item.is_enabled
                    }));
                    logMsg(`[Twitch API] Fetched ${customRewardsList.length} custom rewards.`);
                    
                    // Update the field definition options
                    updateRewardFieldOptions();
                    
                    // Update any existing dropdowns in the DOM
                    updateRewardDropdownsInDOM();
                }
            } else {
                const errText = await response.text();
                logMsg(`[Twitch API Error] Failed to fetch custom rewards: ${response.status} - ${errText}`, true);
            }
        } catch (e) {
            logMsg(`[Twitch API Error] Network error fetching custom rewards: ${e.message}`, true);
        }
    }

    async function fetchTwitchCustomPowerUps() {
        const broadcasterId = currentConfig.resolved_broadcaster_id;
        if (!broadcasterId) {
            logMsg("[Twitch API] Cannot fetch custom power-ups: Broadcaster ID not resolved.");
            return;
        }

        let token = await getValidToken();
        if (!token) {
            logMsg("[Twitch API] Cannot fetch custom power-ups: No valid token.");
            return;
        }

        logMsg("[Twitch API] Fetching custom power-ups from Twitch Helix API...");
        try {
            const url = `https://api.twitch.tv/helix/bits/custom_power_ups?broadcaster_id=${broadcasterId}`;
            const response = await fetch(url, {
                method: "GET",
                headers: {
                    "Client-Id": CLIENT_ID,
                    "Authorization": `Bearer ${token}`
                }
            });

            if (response.ok) {
                const result = await response.json();
                if (result.data) {
                    customPowerUpsList = result.data.map(item => ({
                        id: item.id,
                        title: item.title,
                        cost: item.bits_amount,
                        isEnabled: item.is_enabled
                    }));
                    logMsg(`[Twitch API] Fetched ${customPowerUpsList.length} custom power-ups.`);
                    
                    // Update the field definition options
                    updateRewardFieldOptions();
                    
                    // Update any existing dropdowns in the DOM
                    updateRewardDropdownsInDOM();
                }
            } else {
                const errText = await response.text();
                logMsg(`[Twitch API Error] Failed to fetch custom power-ups: ${response.status} - ${errText}`, true);
            }
        } catch (e) {
            logMsg(`[Twitch API Error] Network error fetching custom power-ups: ${e.message}`, true);
        }
    }

    function updateRewardFieldOptions() {
        const trigDef = window.TheaterController.customTriggers["twitch_event"];
        if (!trigDef || !trigDef.uiConfig || !Array.isArray(trigDef.uiConfig.fields)) return;
        
        const rewardField = trigDef.uiConfig.fields.find(f => f.id === "rewardId");
        if (rewardField) {
            rewardField.type = "select";
            
            const options = [
                { value: "", label: "Any Reward/Power-up" }
            ];
            customRewardsList.forEach(r => {
                options.push({
                    value: r.title,
                    label: `${r.title} (${r.cost} pts)`
                });
            });
            customPowerUpsList.forEach(p => {
                options.push({
                    value: p.title,
                    label: `${p.title} (${p.cost} bits)`
                });
            });
            
            rewardField.options = options;
        }
    }

    function populateRewardDropdown(select, eventType) {
        const currentValue = select.value;
        select.innerHTML = "";

        const options = [];
        if (eventType === "power_up_redeemed") {
            options.push({ value: "", label: "Any Power-up" });
            BASE_POWER_UPS.forEach(bp => {
                options.push({
                    value: bp.title,
                    label: `[Base] ${bp.title} (${bp.cost})`
                });
            });
            customPowerUpsList.forEach(cp => {
                options.push({
                    value: cp.title,
                    label: `${cp.title} (${cp.cost} bits)`
                });
            });
        } else {
            options.push({ value: "", label: "Any Reward" });
            customRewardsList.forEach(r => {
                options.push({
                    value: r.title,
                    label: `${r.title} (${r.cost} pts)`
                });
            });
        }

        if (currentValue && !options.some(o => o.value === currentValue)) {
            options.push({
                value: currentValue,
                label: currentValue
            });
        }

        options.forEach(o => {
            const opt = document.createElement("option");
            opt.value = o.value;
            opt.textContent = o.label;
            if (o.value === currentValue) {
                opt.selected = true;
            }
            select.appendChild(opt);
        });
    }

    function updateRewardDropdownsInDOM() {
        document.querySelectorAll(".trigger-card").forEach(card => {
            const eventTypeSelect = card.querySelector('.t-custom-eventType');
            const select = card.querySelector("select.t-custom-rewardId");
            if (select && eventTypeSelect) {
                populateRewardDropdown(select, eventTypeSelect.value);
            }
        });
    }

    async function resolveUserId(username) {
        const cleanUsername = (username || "").trim().toLowerCase();
        if (!cleanUsername) return null;
        let token = await getValidToken();
        if (!token) return null;
        
        try {
            const response = await fetch(`https://api.twitch.tv/helix/users?login=${cleanUsername}`, {
                method: 'GET',
                headers: {
                    'Client-Id': CLIENT_ID,
                    'Authorization': `Bearer ${token}`
                }
            });
            if (response.ok) {
                const data = await response.json();
                if (data.data && data.data.length > 0) {
                    return data.data[0].id;
                }
            }
        } catch(e) {
            logMsg(`[Twitch API Error] Failed to resolve user ID for "${username}": ${e.message}`, true);
        }
        return null;
    }

    // ─── Twitch IRC WebSocket Client ─────────────────────────────────────────
    let twitchWS = null;
    let twitchIsConnected = false;
    let twitchReconnectTimer = null;

    async function initChatConnection() {
        const broadcaster = (currentConfig.broadcaster_id || "").trim();
        if (!broadcaster) {
            logMsg("[Twitch API] Broadcaster username not configured. Chat connection will not be active.");
            return;
        }

        let token = await getValidToken();
        if (!token) {
            logMsg("[Twitch API Error] Could not connect to chat: Missing OAuth access token.", true);
            return;
        }

        connectTwitchChat(token);
    }

    function connectTwitchChat(token) {
        disconnectTwitchChat();

        const username = (currentConfig.broadcaster_id || "").trim().toLowerCase();
        if (!username || !token) return;

        logMsg(`[Twitch API] Connecting to Twitch Chat for #${username}...`);

        try {
            twitchWS = new WebSocket("wss://irc-ws.chat.twitch.tv:443");
        } catch (e) {
            logMsg(`[Twitch API Error] Failed to create Twitch WebSocket connection: ${e.message}`, true);
            scheduleTwitchReconnect();
            return;
        }

        twitchWS.onopen = () => {
            logMsg("[Twitch API] Connected to Twitch IRC. Authenticating...");
            twitchWS.send(`PASS oauth:${token}`);
            twitchWS.send(`NICK ${username}`);
            twitchWS.send(`JOIN #${username}`);
            twitchWS.send("CAP REQ :twitch.tv/membership twitch.tv/tags twitch.tv/commands");
            twitchIsConnected = true;
        };

        twitchWS.onmessage = (event) => {
            const raw = event.data;
            
            if (raw.startsWith("PING")) {
                twitchWS.send("PONG :tmi.twitch.tv");
                return;
            }

            const lines = raw.split("\r\n");
            lines.forEach(line => {
                if (!line) return;

                if (line.includes("376 ")) { // End of MOTD
                    logMsg(`[Twitch API] Successfully logged in and joined channel #${username}!`);
                }

                // Parse Tags & Message
                let tags = {};
                let messageBody = line;
                if (line.startsWith("@")) {
                    const spaceIdx = line.indexOf(" ");
                    if (spaceIdx !== -1) {
                        const tagsStr = line.substring(1, spaceIdx);
                        messageBody = line.substring(spaceIdx + 1);
                        tagsStr.split(";").forEach(tag => {
                            const [key, val] = tag.split("=");
                            tags[key] = val ? val.replace(/\\s/g, ' ').replace(/\\:/g, ':').replace(/\\r/g, '\r').replace(/\\n/g, '\n') : "";
                        });
                    }
                }

                // PRIVMSG Parser
                const match = messageBody.match(/^:([^!]+)![^ ]+ PRIVMSG #[^ ]+ :(.+)$/);
                if (match) {
                    const sender = tags['display-name'] || match[1];
                    const message = match[2];
                    handleTwitchChatMessage(sender, message, tags);
                    return;
                }

                // USERNOTICE Parser (Subs, Gifted Subs, Raids)
                if (messageBody.includes(" USERNOTICE #")) {
                    const sender = tags['display-name'] || tags['login'] || "Anonymous";
                    const msgId = tags['msg-id'];
                    const customMsgMatch = messageBody.match(/USERNOTICE #[^ ]+ :(.+)$/);
                    const customMessage = customMsgMatch ? customMsgMatch[1] : "";
                    
                    if (msgId === "sub" || msgId === "resub") {
                        const cumulativeMonths = parseInt(tags['msg-param-cumulative-months'] || 1, 10);
                        logMsg(`[Twitch API] Subscription Event: ${sender} subscribed for ${cumulativeMonths} months! Message: ${customMessage}`);
                        
                        const payload = {
                            username: sender,
                            message: customMessage,
                            customData: tags
                        };
                        
                        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                            window.TheaterController.dispatchTrigger("twitch_event", {
                                eventType: "subscription",
                                username: sender,
                                message: customMessage,
                                months: cumulativeMonths
                            }, payload);
                        }
                    } else if (msgId === "subgift" || msgId === "anonsubgift") {
                        const recipient = tags['msg-param-recipient-display-name'] || "someone";
                        logMsg(`[Twitch API] Gifted Subscription Event: ${sender} gifted a sub to ${recipient}!`);
                        
                        const payload = {
                            username: sender,
                            message: `Gifted a sub to ${recipient}`,
                            customData: tags
                        };
                        
                        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                            window.TheaterController.dispatchTrigger("twitch_event", {
                                eventType: "gifted_subscription",
                                username: sender,
                                giftCount: 1
                            }, payload);
                        }
                    } else if (msgId === "raid") {
                        const raider = tags['msg-param-displayName'] || sender;
                        const viewerCount = parseInt(tags['msg-param-viewerCount'] || 0, 10);
                        logMsg(`[Twitch API] Raid Event: ${raider} raided with ${viewerCount} viewers!`);
                        
                        const payload = {
                            username: raider,
                            message: `Raided with ${viewerCount} viewers`,
                            customData: tags
                        };
                        
                        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                            window.TheaterController.dispatchTrigger("twitch_event", {
                                eventType: "host",
                                username: raider,
                                viewerCount: viewerCount
                            }, payload);
                        }
                    }
                    return;
                }

                // CLEARCHAT Parser (Bans, Timeouts, Chat Clears)
                if (messageBody.includes(" CLEARCHAT #")) {
                    const targetMatch = messageBody.match(/CLEARCHAT #[^ ]+ :(.+)$/);
                    if (targetMatch) {
                        const targetUser = targetMatch[1];
                        const duration = tags['ban-duration'];
                        
                        if (duration) {
                            const durationSeconds = parseInt(duration, 10);
                            logMsg(`[Twitch Moderation] User Timed Out: ${targetUser} for ${durationSeconds} seconds.`);
                            
                            if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                                window.TheaterController.dispatchTrigger("twitch_event", {
                                    eventType: "user_timeout",
                                    username: targetUser,
                                    duration: durationSeconds
                                }, { username: targetUser, customData: tags });
                            }
                        } else {
                            logMsg(`[Twitch Moderation] User Banned: ${targetUser} permanently.`);
                            
                            if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                                window.TheaterController.dispatchTrigger("twitch_event", {
                                    eventType: "user_banned",
                                    username: targetUser
                                }, { username: targetUser, customData: tags });
                            }
                        }
                    } else {
                        logMsg(`[Twitch Moderation] Chat cleared by a moderator.`);
                        
                        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                            window.TheaterController.dispatchTrigger("twitch_event", {
                                eventType: "chat_cleared"
                            }, { username: "System", customData: tags });
                        }
                    }
                    return;
                }

                // CLEARMSG Parser (Message Deleted)
                if (messageBody.includes(" CLEARMSG #")) {
                    const login = tags['login'];
                    const targetMsgId = tags['target-msg-id'];
                    const deletedMsgMatch = messageBody.match(/CLEARMSG #[^ ]+ :(.+)$/);
                    const deletedMsg = deletedMsgMatch ? deletedMsgMatch[1] : "";
                    
                    logMsg(`[Twitch API] Message deleted from ${login} (ID: ${targetMsgId})`);
                    
                    if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                        window.TheaterController.dispatchTrigger("twitch_event", {
                            eventType: "message_deleted",
                            username: login,
                            messageId: targetMsgId
                        }, { username: login, message: deletedMsg, customData: tags });
                    }
                }
            });
        };

        twitchWS.onerror = (err) => {
            logMsg("[Twitch API Error] Twitch WebSocket error occurred.", true);
        };

        twitchWS.onclose = () => {
            twitchIsConnected = false;
            logMsg("[Twitch API] Twitch WebSocket connection closed.");
            scheduleTwitchReconnect();
        };
    }

    function disconnectTwitchChat() {
        clearTimeout(twitchReconnectTimer);
        twitchReconnectTimer = null;
        if (twitchWS) {
            twitchWS.onopen = null;
            twitchWS.onmessage = null;
            twitchWS.onerror = null;
            twitchWS.onclose = null;
            if (twitchWS.readyState === WebSocket.OPEN || twitchWS.readyState === WebSocket.CONNECTING) {
                twitchWS.close();
            }
            twitchWS = null;
        }
        twitchIsConnected = false;
    }

    function scheduleTwitchReconnect() {
        clearTimeout(twitchReconnectTimer);
        twitchReconnectTimer = setTimeout(() => {
            logMsg("[Twitch API] Reconnecting to Twitch chat...");
            initChatConnection();
        }, 10000);
    }

    function handleTwitchChatMessage(senderName, messageText, tags) {
        const isSubscriber = tags.subscriber === "1";
        const isModerator = tags.mod === "1" || (tags.badges && (tags.badges.includes("broadcaster") || tags.badges.includes("moderator")));

        const payload = {
            username: senderName,
            message: messageText,
            customData: {
                subscriber: isSubscriber,
                moderator: isModerator,
                id: tags.id || "",
                'user-id': tags['user-id'] || "",
                'room-id': tags['room-id'] || "",
                'tmi-sent-ts': tags['tmi-sent-ts'] || ""
            }
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("twitch_event", {
                eventType: "message",
                message: messageText,
                username: senderName,
                subscriber: isSubscriber,
                moderator: isModerator
            }, payload);
        }

        // Handle Bits Cheer event
        const bits = tags.bits ? parseInt(tags.bits, 10) : 0;
        if (bits > 0) {
            const cheerPayload = {
                username: senderName,
                message: messageText,
                customData: Object.assign({}, payload.customData, {
                    bits: bits,
                    username: senderName,
                    message: messageText
                })
            };
            logMsg(`[Twitch API] Bits Cheer Event: ${senderName} cheered ${bits} bits! Message: ${messageText}`);
            if (window.TheaterController && window.TheaterController.dispatchTrigger) {
                window.TheaterController.dispatchTrigger("twitch_event", {
                    eventType: "cheer",
                    username: senderName,
                    message: messageText,
                    bits: bits
                }, cheerPayload);
            }
        }
    }

    // ─── Twitch Outbound Chat Sender ──────────────────────────────────────────
    async function sendTwitchMessage(msg) {
        const broadcasterSetting = (currentConfig.broadcaster_id || "").trim();
        if (!broadcasterSetting) {
            logMsg("[Twitch API Error] Message not sent: Broadcaster setting is missing.", true);
            return;
        }

        const trimmed = (msg || "").trim();
        if (trimmed.startsWith("/")) {
            // Parse slash command and run via Helix API instead of sending via raw PRIVMSG (which Twitch blocked)
            const spaceIdx = trimmed.indexOf(" ");
            const cmd = spaceIdx !== -1 ? trimmed.substring(1, spaceIdx).toLowerCase() : trimmed.substring(1).toLowerCase();
            const argsStr = spaceIdx !== -1 ? trimmed.substring(spaceIdx + 1).trim() : "";
            
            if (cmd === "raid") {
                if (argsStr) {
                    startRaidTwitchUser(argsStr);
                } else {
                    logMsg("[Twitch API Error] Usage: /raid <channel_name>", true);
                }
                return;
            } else if (cmd === "unraid" || cmd === "cancelraid") {
                cancelRaidTwitch();
                return;
            } else if (cmd === "shoutout") {
                if (argsStr) {
                    shoutoutTwitchUser(argsStr);
                } else {
                    logMsg("[Twitch API Error] Usage: /shoutout <channel_name>", true);
                }
                return;
            } else if (cmd === "ban") {
                const parts = argsStr.split(/\s+/);
                const target = parts[0];
                const reason = parts.slice(1).join(" ") || "Automated moderation";
                if (target) {
                    banTwitchUser(target, 0, reason);
                } else {
                    logMsg("[Twitch API Error] Usage: /ban <username> [reason]", true);
                }
                return;
            } else if (cmd === "timeout") {
                const parts = argsStr.split(/\s+/);
                const target = parts[0];
                let duration = 600;
                let reason = "Automated moderation";
                if (parts[1] && !isNaN(parts[1])) {
                    duration = parseInt(parts[1], 10);
                    reason = parts.slice(2).join(" ") || reason;
                } else {
                    reason = parts.slice(1).join(" ") || reason;
                }
                if (target) {
                    banTwitchUser(target, duration, reason);
                } else {
                    logMsg("[Twitch API Error] Usage: /timeout <username> [duration_seconds] [reason]", true);
                }
                return;
            } else if (cmd === "unban") {
                if (argsStr) {
                    unbanTwitchUser(argsStr);
                } else {
                    logMsg("[Twitch API Error] Usage: /unban <username>", true);
                }
                return;
            } else if (cmd === "clear") {
                clearTwitchChat();
                return;
            } else if (cmd === "announce") {
                if (argsStr) {
                    sendTwitchAnnouncement(argsStr, "primary");
                } else {
                    logMsg("[Twitch API Error] Usage: /announce <message>", true);
                }
                return;
            }
        }

        let token = await getValidToken();
        if (!token) return;

        if (!twitchWS || twitchWS.readyState !== WebSocket.OPEN || !twitchIsConnected) {
            logMsg("[Twitch API] Reconnecting WebSocket to send message...");
            connectTwitchChat(token);
        }

        if (twitchWS && twitchWS.readyState === WebSocket.OPEN) {
            twitchWS.send(`PRIVMSG #${broadcasterSetting.toLowerCase()} :${msg}`);
            logMsg(`[Twitch API] Sent message to Twitch chat: ${msg}`);
        } else {
            logMsg("[Twitch API Error] Message not sent. Twitch IRC client is not connected.", true);
        }
    }

    // ─── Twitch Helix API Moderation & Chat Actions ───────────────────────────
    async function banTwitchUser(targetUsername, durationSeconds, reason) {
        const broadcasterId = currentConfig.resolved_broadcaster_id;
        if (!broadcasterId) {
            logMsg("[Twitch API Error] Broadcaster ID is not resolved yet.", true);
            return;
        }
        let token = await getValidToken();
        if (!token) return;

        const targetUserId = await resolveUserId(targetUsername);
        if (!targetUserId) {
            logMsg(`[Twitch API Error] Could not resolve target user "${targetUsername}"`, true);
            return;
        }

        logMsg(`[Twitch API] Banning/Timing out ${targetUsername} (${targetUserId}) for ${durationSeconds || 'permanent'}...`);
        try {
            const payload = {
                data: {
                    user_id: targetUserId,
                    reason: reason || "Automated moderation"
                }
            };
            if (durationSeconds) {
                payload.data.duration = durationSeconds;
            }

            const response = await fetch(`https://api.twitch.tv/helix/moderation/bans?broadcaster_id=${broadcasterId}&moderator_id=${broadcasterId}`, {
                method: 'POST',
                headers: {
                    'Client-Id': CLIENT_ID,
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Twitch API Error] Failed to ban/timeout: ${response.status} - ${errText}`, true);
            } else {
                logMsg(`[Twitch API] Successfully banned/timed out ${targetUsername}.`);
            }
        } catch(e) {
            logMsg(`[Twitch API Error] Error during ban/timeout: ${e.message}`, true);
        }
    }

