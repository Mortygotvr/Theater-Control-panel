{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "*"
  ],
  "remote": {
    "urls": ["http://*/*", "https://*/*"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-title"
  ]
}
