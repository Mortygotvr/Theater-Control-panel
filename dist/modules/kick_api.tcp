// @theater-tcp-module
(function() {
    const MODULE_ID = "kick_api";
    let currentConfig = {};
    let triggerObserver = null;

    // Polyfill window.saveConfig if it is missing in the control panel
    if (!window.saveConfig) {
        window.saveConfig = function() {
            if (window.config) {
                localStorage.setItem("obs_bridge_config", JSON.stringify(window.config));
            }
        };
    }

    // Hardcoded Client Credentials and Google Apps Script Proxy URL
    const CLIENT_ID = "01KSMDKC9KR86WH1TBVNNSDCW4";
    const CLIENT_SECRET = "";
    const REDIRECT_URI = "http://127.0.0.1:52246/";
    const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbw4ptHi8idUT9Ue7ChzK_w7i_SAtEc_ib2vwhUJxnUfbJsuWciX1R7E6PDzOV_inOE6/exec";

    const MODULE_DEFINITION = {
        name: "Kick API",
        description: "Sends automated messages to your Kick channel chat room using the official Kick API (handles token authorization and automatic background refreshing).",
        configFields: [
            {
                id: "broadcaster_id",
                label: "Your Kick Broadcaster Username (e.g. mortygotvr) <button class='btn-green' onclick='window.TheaterController.modules.kick_api.definition.authorizeApp()' style='margin-left: 10px; font-size: 0.85em; padding: 3px 8px; cursor: pointer; display: inline-block; vertical-align: middle; border-radius: 4px; border: none;'>🔗 Connect Account</button>",
                type: "text",
                default: ""
            }
        ],
        variablePresets: [
            {
                id: "kick-chat",
                label: "Kick: Chat Message",
                optgroupLabel: "Kick Presets",
                samplePayload: {
                    "username": "broadcaster_username",
                    "message": "Hello stream! Check out this link: https://kick.com",
                    "customData": {
                        "id": "abc-123-xyz",
                        "content": "Hello stream! Check out this link: https://kick.com",
                        "sender": {
                            "id": 987654,
                            "username": "viewer_chatter",
                            "identity": {
                                "color": "#00FF00"
                            }
                        },
                        "subscriber": true,
                        "mod": true,
                        "vip": false,
                        "badges": "[SUB][MOD]"
                    }
                }
            },
            {
                id: "kick-follow",
                label: "Kick: Channel Follow",
                optgroupLabel: "Kick Presets",
                samplePayload: {
                    "username": "new_follower",
                    "message": "",
                    "customData": {
                        "id": 1234567,
                        "username": "new_follower"
                    }
                }
            },
            {
                id: "kick-sub",
                label: "Kick: Subscription",
                optgroupLabel: "Kick Presets",
                samplePayload: {
                    "username": "subscriber_user",
                    "message": "",
                    "customData": {
                        "id": 554433,
                        "username": "subscriber_user",
                        "months": 6
                    }
                }
            },
            {
                id: "kick-giftsub",
                label: "Kick: Gifted Subscription",
                optgroupLabel: "Kick Presets",
                samplePayload: {
                    "username": "gifter_user",
                    "message": "",
                    "customData": {
                        "gifter": "gifter_user",
                        "recipient": "lucky_viewer",
                        "gift_count": 5
                    }
                }
            },
            {
                id: "kick-redeem",
                label: "Kick: Reward Redemption",
                optgroupLabel: "Kick Presets",
                samplePayload: {
                    "username": "redeemer_user",
                    "message": "",
                    "customData": {
                        "reward": {
                            "title": "Do 10 Pushups",
                            "cost": 1000
                        },
                        "user": {
                            "username": "redeemer_user"
                        }
                    }
                }
            },
            {
                id: "kick-raid",
                label: "Kick: Raid Start",
                optgroupLabel: "Kick Presets",
                samplePayload: {
                    "username": "raider_channel",
                    "message": "",
                    "customData": {
                        "host_username": "raider_channel",
                        "viewers": 42
                    }
                }
            },
            {
                id: "kick-ban",
                label: "Kick: User Banned",
                optgroupLabel: "Kick Presets",
                samplePayload: {
                    "username": "banned_user",
                    "message": "",
                    "customData": {
                        "user": {
                            "username": "banned_user"
                        },
                        "moderator": {
                            "username": "moderator_name"
                        }
                    }
                }
            },
            {
                id: "kick-timeout",
                label: "Kick: User Timed Out",
                optgroupLabel: "Kick Presets",
                samplePayload: {
                    "username": "timedout_user",
                    "message": "",
                    "customData": {
                        "user": {
                            "username": "timedout_user"
                        },
                        "duration": 600,
                        "moderator": {
                            "username": "moderator_name"
                        }
                    }
                }
            },
            {
                id: "kick-get-channel-info",
                label: "Kick: Get Channel Info Details",
                optgroupLabel: "Get Command Presets",
                samplePayload: {
                    "kick_channel": {
                        "id": 1234567,
                        "user_id": 987654,
                        "slug": "kickdev",
                        "is_banned": false,
                        "playback_url": "https://stream.kick.com/kickdev",
                        "name_username": "KickDev",
                        "user": {
                            "id": 987654,
                            "username": "kickdev",
                            "profile_pic": "https://files.kick.com/images/user/987654/profile_image.png"
                        },
                        "chatroom": {
                            "id": 112233,
                            "chat_mode_old": "public",
                            "subscription_enabled": true,
                            "followers_only": false
                        },
                        "livestream": {
                            "id": 998877,
                            "slug": "kickdev-live",
                            "channel_id": 1234567,
                            "title": "Building awesome interactive streams!",
                            "viewers": 150,
                            "category": {
                                "id": 1,
                                "name": "Just Chatting"
                            }
                        }
                    }
                }
            }
        ],
        onLoad(moduleConfig) {
            logMsg("[Kick API] Module loaded successfully.");
            currentConfig = moduleConfig;
            
            // Seed hardcoded credentials and proxy settings
            currentConfig.client_id = CLIENT_ID;
            currentConfig.redirect_uri = REDIRECT_URI;
            currentConfig.google_script_url = GOOGLE_SCRIPT_URL;

            // Auto-migrate settings from old kick_chat module if kick_api is unconfigured
            if (!currentConfig.broadcaster_id && window.config && window.config.modules && window.config.modules.kick_chat) {
                logMsg("[Kick API] Migrating configuration from legacy kick_chat module...");
                const legacy = window.config.modules.kick_chat;
                for (const key in legacy) {
                    currentConfig[key] = legacy[key];
                }
                if (!window.config.modules.kick_api) window.config.modules.kick_api = {};
                Object.assign(window.config.modules.kick_api, legacy);
                if (window.saveConfig) window.saveConfig();
            }

            // Automatically migrate legacy triggers & commands
            migrateOldTriggersAndCommands();

            // Autocomplete Setup
            injectStyles();
            document.addEventListener('input', handleInput);
            document.addEventListener('keydown', handleKeyDown, true);
            document.addEventListener('click', handleClick);

            // Warning Observer Setup
            startObservingTriggers();

            // Auto-exchange if auth_code is present but tokens are not
            if (currentConfig.auth_code && (!currentConfig.access_token || !currentConfig.refresh_token)) {
                logMsg("[Kick API] Saved Authorization Code detected without tokens. Initiating automatic exchange...");
                setTimeout(() => {
                    MODULE_DEFINITION.exchangeCode();
                }, 1000);
            }

            // Connect to Kick Chatroom WebSocket
            initChatConnection();
        },
        onUnload() {
            logMsg("[Kick API] Module unloaded.");
            
            // Clean up Tauri OAuth listener if active
            if (window.kickAuthUnlisten) {
                try { window.kickAuthUnlisten(); } catch (e) {}
                window.kickAuthUnlisten = null;
            }

            // Disconnect Kick chat WebSocket
            disconnectKickChat();

            // Autocomplete Cleanup
            document.removeEventListener('input', handleInput);
            document.removeEventListener('keydown', handleKeyDown, true);
            document.removeEventListener('click', handleClick);
            hideMenu();
            removeStyles();

            // Warning Observer Cleanup
            stopObservingTriggers();
            document.querySelectorAll(".kick-ban-warning").forEach(el => el.remove());
        },

        // Helper functions exposed on the definition for the UI
        async authorizeApp() {
            try {
                const clientId = CLIENT_ID;
                const redirectUri = REDIRECT_URI;

                const verifier = generateCodeVerifier();
                const challenge = await generateCodeChallenge(verifier);
                const state = Math.random().toString(36).substring(2, 15);
                
                localStorage.setItem("kick_pkce_verifier", verifier);
                localStorage.setItem("kick_pkce_state", state);

                const authUrl = `https://id.kick.com/oauth/authorize?response_type=code&client_id=${clientId}&redirect_uri=${encodeURIComponent(redirectUri)}&scope=user:read%20channel:read%20channel:write%20channel:rewards:read%20channel:rewards:write%20chat:read%20chat:write%20events:subscribe%20moderation:chat_message:manage%20moderation:ban&code_challenge=${challenge}&code_challenge_method=S256&state=${state}`;
                
                // Parse redirect port if it is a local loopback HTTP server
                let isLoopback = false;
                let loopbackPort = 52246;
                try {
                    const u = new URL(redirectUri);
                    if ((u.hostname === "127.0.0.1" || u.hostname === "localhost") && u.port) {
                        isLoopback = true;
                        loopbackPort = parseInt(u.port, 10);
                    }
                } catch(e) {}

                if (window.__TAURI__) {
                    if (window.kickAuthUnlisten) {
                        try { window.kickAuthUnlisten(); } catch (e) {}
                        window.kickAuthUnlisten = null;
                    }

                    if (isLoopback) {
                        // Loopback server flow (Option B - Default System Browser)
                        window.__TAURI__.event.listen('kick-loopback-code', (event) => {
                            const path = event.payload; // e.g. "/?code=xyz&state=abc"
                            logMsg(`[Kick API] Automatically captured loopback redirect: ${path}`);
                            try {
                                const urlObj = new URL("http://localhost" + path);
                                const code = urlObj.searchParams.get('code');
                                if (code) {
                                    logMsg(`[Kick API] Extracted authorization code: ${code}`);
                                    currentConfig.auth_code = code;
                                    
                                    if (window.kickAuthUnlisten) {
                                        window.kickAuthUnlisten();
                                        window.kickAuthUnlisten = null;
                                    }

                                    logMsg(`[Kick API] Triggering automatic code exchange...`);
                                    setTimeout(() => {
                                        MODULE_DEFINITION.exchangeCode(code);
                                    }, 500);
                                }
                            } catch(err) {
                                logMsg(`[Kick API Error] Failed to parse loopback redirect: ${err.message}`, true);
                            }
                        }).then(unlistenFn => {
                            window.kickAuthUnlisten = unlistenFn;
                        });

                        // Start Rust loopback server & open default system browser
                        window.__TAURI__.core.invoke('start_loopback_listener', {
                            port: loopbackPort,
                            eventName: 'kick-loopback-code'
                        }).catch(err => {
                            logMsg(`[Kick API Error] Failed to start loopback listener: ${err}`, true);
                        });

                        window.__TAURI__.core.invoke('open_in_browser', { url: authUrl }).catch(err => {
                            logMsg(`[Kick API Error] Failed to open default browser: ${err}`, true);
                            window.open(authUrl, '_blank');
                        });

                    } else {
                        // Webview window popup flow (Option A - Tauri Webview Popup)
                        window.__TAURI__.event.listen('kick-oauth-code', (event) => {
                            const redirectUrl = event.payload;
                            logMsg(`[Kick API] Automatically captured webview redirect: ${redirectUrl}`);
                            try {
                                const urlObj = new URL(redirectUrl);
                                const code = urlObj.searchParams.get('code');
                                if (code) {
                                    logMsg(`[Kick API] Extracted authorization code: ${code}`);
                                    currentConfig.auth_code = code;
                                    
                                    if (window.kickAuthUnlisten) {
                                        window.kickAuthUnlisten();
                                        window.kickAuthUnlisten = null;
                                    }

                                    logMsg(`[Kick API] Triggering automatic code exchange...`);
                                    setTimeout(() => {
                                        MODULE_DEFINITION.exchangeCode(code);
                                    }, 500);
                                }
                            } catch (err) {
                                logMsg(`[Kick API Error] Failed to parse webview redirect: ${err.message}`, true);
                            }
                        }).then(unlistenFn => {
                            window.kickAuthUnlisten = unlistenFn;
                        });

                        window.__TAURI__.core.invoke('open_oauth_window', {
                            url: authUrl,
                            redirectUriPrefix: redirectUri,
                            eventName: 'kick-oauth-code'
                        }).catch(err => {
                            logMsg(`[Kick API Error] Failed to open Tauri auth window: ${err}`, true);
                            window.open(authUrl, '_blank');
                        });
                    }
                } else {
                    window.open(authUrl, '_blank');
                }
            } catch (err) {
                logMsg(`[Kick API Error] Failed to generate PKCE challenge: ${err.message}`, true);
                alert(`Failed to start authorization flow: ${err.message}`);
            }
        },

        async exchangeCode() {
            const authCodeField = document.querySelector(`.mod-field-kick_api[data-field-id="auth_code"]`);
            const authCode = authCodeField ? authCodeField.value.trim() : (currentConfig.auth_code || "").trim();

            const clientIdField = document.querySelector(`.mod-field-kick_api[data-field-id="client_id"]`);
            const clientId = (clientIdField ? clientIdField.value.trim() : "").trim() || CLIENT_ID;

            const clientSecretField = document.querySelector(`.mod-field-kick_api[data-field-id="client_secret"]`);
            const clientSecret = (clientSecretField ? clientSecretField.value.trim() : "").trim() || CLIENT_SECRET;

            const redirectUriField = document.querySelector(`.mod-field-kick_api[data-field-id="redirect_uri"]`);
            const redirectUri = (redirectUriField ? redirectUriField.value.trim() : "").trim() || currentConfig.redirect_uri || "http://127.0.0.1:52246/";

            const googleScriptUrlField = document.querySelector(`.mod-field-kick_api[data-field-id="google_script_url"]`);
            const googleScriptUrl = (googleScriptUrlField ? googleScriptUrlField.value.trim() : "").trim() || currentConfig.google_script_url || "";

            if (!authCode) {
                alert("Please paste the Authorization Code first.");
                return;
            }

            const verifier = localStorage.getItem("kick_pkce_verifier");
            if (!verifier) {
                alert("Missing PKCE Code Verifier. Please click '1. Authorize App' first.");
                return;
            }

            logMsg("[Kick API] Exchanging authorization code for tokens...");

            try {
                let response;
                if (googleScriptUrl) {
                    logMsg(`[Kick API] Routing exchange through Google Apps Script proxy: ${googleScriptUrl}`);
                    response = await fetch(googleScriptUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'text/plain'
                        },
                        body: JSON.stringify({
                            action: 'exchange',
                            code: authCode,
                            redirect_uri: redirectUri,
                            code_verifier: verifier,
                            client_id: clientId
                        })
                    });
                } else {
                    const params = new URLSearchParams();
                    params.append('grant_type', 'authorization_code');
                    params.append('code', authCode);
                    params.append('redirect_uri', redirectUri);
                    params.append('client_id', clientId);
                    params.append('client_secret', clientSecret);
                    params.append('code_verifier', verifier);

                    response = await fetch('https://id.kick.com/oauth/token', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded'
                        },
                        body: params
                    });
                }

                if (!response.ok) {
                    const errText = await response.text();
                    logMsg(`[Kick API Error] OAuth exchange failed: ${response.status} ${response.statusText} - ${errText}`, true);
                    alert(`OAuth exchange failed: ${response.statusText}`);
                    return;
                }

                const data = await response.json();
                if (data.error) {
                    logMsg(`[Kick API Error] Proxy exchange returned error: ${data.error_description || data.error}`, true);
                    alert(`OAuth exchange failed: ${data.error_description || data.error}`);
                    return;
                }

                if (data.access_token && data.refresh_token) {
                    // Update module config in memory
                    currentConfig.client_id = clientId;
                    currentConfig.client_secret = googleScriptUrl ? "" : clientSecret;
                    currentConfig.redirect_uri = redirectUri;
                    currentConfig.google_script_url = googleScriptUrl;
                    currentConfig.access_token = data.access_token;
                    currentConfig.refresh_token = data.refresh_token;
                    currentConfig.token_expires_at = Date.now() + (data.expires_in * 1000);

                    // Persist to window.config
                    if (window.config) {
                        if (!window.config.modules) window.config.modules = {};
                        if (!window.config.modules.kick_api) window.config.modules.kick_api = {};
                        
                        window.config.modules.kick_api.client_id = clientId;
                        window.config.modules.kick_api.client_secret = googleScriptUrl ? "" : clientSecret;
                        window.config.modules.kick_api.redirect_uri = redirectUri;
                        window.config.modules.kick_api.google_script_url = googleScriptUrl;
                        window.config.modules.kick_api.auth_code = authCode;
                        window.config.modules.kick_api.access_token = data.access_token;
                        window.config.modules.kick_api.refresh_token = data.refresh_token;
                        window.config.modules.kick_api.token_expires_at = currentConfig.token_expires_at;
                        if (window.saveConfig) window.saveConfig();
                    }

                    logMsg("[Kick API] Tokens successfully generated and saved! Setup is complete.");
                    alert("OAuth setup successful! Your tokens have been generated and saved.");

                    // Connect to Kick Chatroom WebSocket
                    initChatConnection();
                } else {
                    logMsg("[Kick API Error] OAuth exchange response did not contain tokens.", true);
                }
            } catch (err) {
                logMsg(`[Kick API Error] Network error during OAuth exchange: ${err.message}`, true);
                alert(`Network error during OAuth exchange: ${err.message}`);
            }
        }
    };

    // Automatically migrate legacy triggers & commands to the new unified event schemas
    function migrateOldTriggersAndCommands() {
        if (!window.config || !Array.isArray(window.config.triggers)) return;

        let migratedAny = false;

        window.config.triggers.forEach(t => {
            // 1. Migrate Triggers
            if (t.triggerType && t.triggerType.startsWith("kick_") && t.triggerType !== "kick_event") {
                const oldType = t.triggerType;
                t.triggerType = "kick_event";
                migratedAny = true;

                if (oldType === "kick_chat_message") {
                    t.eventType = "message";
                } else if (oldType === "kick_subscription") {
                    t.eventType = "subscription";
                } else if (oldType === "kick_gifted_subscription") {
                    t.eventType = "gifted_subscription";
                } else if (oldType === "kick_user_banned") {
                    t.eventType = "user_banned";
                } else if (oldType === "kick_user_unbanned") {
                    t.eventType = "user_unbanned";
                } else if (oldType === "kick_message_deleted") {
                    t.eventType = "message_deleted";
                } else if (oldType === "kick_pinned_message") {
                    t.eventType = "pinned_message";
                } else if (oldType === "kick_pinned_message_deleted") {
                    t.eventType = "pinned_message_deleted";
                } else if (oldType === "kick_chat_cleared") {
                    t.eventType = "chat_cleared";
                } else if (oldType === "kick_poll_updated") {
                    t.eventType = "poll_updated";
                }
                logMsg(`[Kick API] Migrated legacy trigger type "${oldType}" to "kick_event" (eventType: "${t.eventType}")`);
            }

            // 2. Migrate Commands inside Triggers
            if (Array.isArray(t.commands)) {
                t.commands.forEach(cmd => {
                    if (cmd.type && cmd.type.startsWith("kick_") && cmd.type !== "kick_command") {
                        const oldCmdType = cmd.type;
                        cmd.type = "kick_command";
                        migratedAny = true;

                        if (oldCmdType === "kick_send_message") {
                            cmd.commandType = "send_message";
                        } else if (oldCmdType === "kick_ban_user") {
                            cmd.commandType = "ban_user";
                        } else if (oldCmdType === "kick_timeout_user") {
                            cmd.commandType = "timeout_user";
                        } else if (oldCmdType === "kick_unban_user") {
                            cmd.commandType = "unban_user";
                        } else if (oldCmdType === "kick_clear_chat") {
                            cmd.commandType = "clear_chat";
                        } else if (oldCmdType === "kick_update_stream") {
                            cmd.commandType = "update_stream";
                        }
                        logMsg(`[Kick API] Migrated legacy command type "${oldCmdType}" to "kick_command" (commandType: "${cmd.commandType}")`);
                    }
                });
            }
        });

        // 3. Migrate legacy commands stored in button grid if there is any button deck
        if (window.config.buttons && typeof window.config.buttons === "object") {
            Object.values(window.config.buttons).forEach(btn => {
                if (btn && Array.isArray(btn.commands)) {
                    btn.commands.forEach(cmd => {
                        if (cmd.type && cmd.type.startsWith("kick_") && cmd.type !== "kick_command") {
                            const oldCmdType = cmd.type;
                            cmd.type = "kick_command";
                            migratedAny = true;

                            if (oldCmdType === "kick_send_message") {
                                cmd.commandType = "send_message";
                            } else if (oldCmdType === "kick_ban_user") {
                                cmd.commandType = "ban_user";
                            } else if (oldCmdType === "kick_timeout_user") {
                                cmd.commandType = "timeout_user";
                            } else if (oldCmdType === "kick_unban_user") {
                                cmd.commandType = "unban_user";
                            } else if (oldCmdType === "kick_clear_chat") {
                                cmd.commandType = "clear_chat";
                            } else if (oldCmdType === "kick_update_stream") {
                                cmd.commandType = "update_stream";
                            }
                            logMsg(`[Kick API] Migrated legacy button command type "${oldCmdType}" to "kick_command" (commandType: "${cmd.commandType}")`);
                        }
                    });
                }
            });
        }

        if (migratedAny) {
            logMsg("[Kick API] Saved configuration automatically migrated to unified Kick Event/Command schema.");
            if (window.saveConfig) window.saveConfig();
        }
    }

    // ─── Kick Autocomplete Suggestion Helper ──────────────────────────────────
    const KICK_COMMANDS = [
        { cmd: "/ban", desc: "/ban <user> [reason]" },
        { cmd: "/timeout", desc: "/timeout <user> [seconds]" },
        { cmd: "/unban", desc: "/unban <user>" },
        { cmd: "/clear", desc: "/clear (clears chat)" },
        { cmd: "/user", desc: "/user <user> (view info)" },
        { cmd: "/mod", desc: "/mod <user>" },
        { cmd: "/unmod", desc: "/unmod <user>" },
        { cmd: "/og", desc: "/og <user>" },
        { cmd: "/unog", desc: "/unog <user>" },
        { cmd: "/slow", desc: "/slow <seconds> (or /slow off)" },
        { cmd: "/followonly", desc: "/followonly <minutes> (or off)" },
        { cmd: "/subonly", desc: "/subonly (or off)" },
        { cmd: "/emoteonly", desc: "/emoteonly (or off)" }
    ];

    let activeIndex = 0;
    let filteredCommands = [];
    let activeInput = null;

    function injectStyles() {
        const styleId = "kick-autocomplete-styles";
        if (document.getElementById(styleId)) return;
        const style = document.createElement("style");
        style.id = styleId;
        style.innerHTML = `
            #kick-autocomplete-menu {
                position: absolute;
                background: rgba(25, 25, 25, 0.98);
                border: 1px solid var(--accent, #007acc);
                border-radius: 6px;
                box-shadow: 0 8px 24px rgba(0, 0, 0, 0.7), 0 0 10px rgba(0, 122, 204, 0.25);
                z-index: 100000;
                max-height: 200px;
                overflow-y: auto;
                font-family: 'Outfit', sans-serif;
                box-sizing: border-box;
                backdrop-filter: blur(8px);
                scrollbar-width: thin;
                scrollbar-color: var(--accent, #007acc) #1a1a1a;
            }
            #kick-autocomplete-menu::-webkit-scrollbar {
                width: 6px;
            }
            #kick-autocomplete-menu::-webkit-scrollbar-track {
                background: #1a1a1a;
            }
            #kick-autocomplete-menu::-webkit-scrollbar-thumb {
                background: var(--accent, #007acc);
                border-radius: 3px;
            }
            .kick-autocomplete-item {
                padding: 8px 12px;
                cursor: pointer;
                display: flex;
                flex-direction: column;
                border-bottom: 1px solid #333;
                transition: all 0.15s ease;
                box-sizing: border-box;
            }
            .kick-autocomplete-item:last-child {
                border-bottom: none;
            }
            .kick-autocomplete-item.active {
                background: var(--accent, #007acc);
            }
            .kick-autocomplete-item:hover {
                background: rgba(255, 255, 255, 0.05);
            }
            .kick-autocomplete-item.active:hover {
                background: var(--accent, #007acc);
            }
            .kick-autocomplete-cmd {
                font-weight: bold;
                color: #ffffff;
                font-size: 0.95em;
            }
            .kick-autocomplete-desc {
                font-size: 0.8em;
                color: #aaa;
                margin-top: 2px;
            }
            .kick-autocomplete-item.active .kick-autocomplete-desc {
                color: #e0e0e0;
            }
        `;
        document.head.appendChild(style);
    }

    function removeStyles() {
        const style = document.getElementById("kick-autocomplete-styles");
        if (style) style.remove();
    }

    function showMenu(input, commands) {
        activeInput = input;
        filteredCommands = commands;
        activeIndex = 0;

        let menu = document.getElementById("kick-autocomplete-menu");
        if (!menu) {
            menu = document.createElement("div");
            menu.id = "kick-autocomplete-menu";
            document.body.appendChild(menu);
        }

        renderMenuContent(menu);
        positionMenu(menu, input);
    }

    function hideMenu() {
        const menu = document.getElementById("kick-autocomplete-menu");
        if (menu) menu.remove();
        activeInput = null;
        filteredCommands = [];
    }

    function positionMenu(menu, input) {
        const rect = input.getBoundingClientRect();
        menu.style.top = (window.scrollY + rect.bottom + 4) + "px";
        menu.style.left = (window.scrollX + rect.left) + "px";
        menu.style.width = rect.width + "px";
    }

    function renderMenuContent(menu) {
        menu.innerHTML = "";
        filteredCommands.forEach((item, index) => {
            const div = document.createElement("div");
            div.className = `kick-autocomplete-item ${index === activeIndex ? 'active' : ''}`;
            div.innerHTML = `
                <span class="kick-autocomplete-cmd">${item.cmd}</span>
                <span class="kick-autocomplete-desc">${item.desc}</span>
            `;
            div.onclick = (e) => {
                e.stopPropagation();
                selectCommand(item.cmd);
            };
            menu.appendChild(div);
        });
        
        // Auto scroll to active item
        const activeItem = menu.children[activeIndex];
        if (activeItem) {
            activeItem.scrollIntoView({ block: "nearest" });
        }
    }

    function selectCommand(cmd) {
        if (!activeInput) return;
        activeInput.value = cmd + " ";
        // Dispatch events so that the save action hooks trigger
        activeInput.dispatchEvent(new Event('input', { bubbles: true }));
        activeInput.dispatchEvent(new Event('change', { bubbles: true }));
        activeInput.focus();
        hideMenu();
    }

    function handleInput(e) {
        const target = e.target;
        if (!target || !target.classList.contains('cmd-custom-message')) {
            hideMenu();
            return;
        }

        // Verify it is indeed the kick_command command row
        const commandRow = target.closest('.command-row');
        if (!commandRow) {
            hideMenu();
            return;
        }
        const typeSelect = commandRow.querySelector('.cmd-type');
        if (!typeSelect || typeSelect.value !== 'kick_command') {
            hideMenu();
            return;
        }

        const commandTypeSelect = commandRow.querySelector('.cmd-custom-commandType');
        if (!commandTypeSelect || commandTypeSelect.value !== 'send_message') {
            hideMenu();
            return;
        }

        // Update ban warning dynamically
        updateBanWarning(target);

        const value = target.value;
        if (value.startsWith("/")) {
            const query = value.toLowerCase();
            const matches = KICK_COMMANDS.filter(item => 
                item.cmd.toLowerCase().startsWith(query)
            );
            if (matches.length > 0) {
                showMenu(target, matches);
            } else {
                hideMenu();
            }
        } else {
            hideMenu();
        }
    }

    function updateBanWarning(input) {
        if (!input) return;
        const parent = input.parentElement;
        if (!parent) return;

        const val = (input.value || "").trim().toLowerCase();
        // Check if command is an automated ban or kick
        const hasWarning = val.startsWith("/ban") || val.startsWith("/kick");
        
        let warningEl = parent.querySelector(".kick-ban-warning");
        
        if (hasWarning) {
            if (!warningEl) {
                warningEl = document.createElement("div");
                warningEl.className = "kick-ban-warning";
                warningEl.style.cssText = `
                    color: #ffb74d;
                    font-size: 0.82em;
                    margin-top: 6px;
                    display: flex;
                    align-items: flex-start;
                    gap: 6px;
                    background: rgba(255, 183, 77, 0.08);
                    border: 1px solid rgba(255, 183, 77, 0.25);
                    padding: 8px 10px;
                    border-radius: 4px;
                    box-sizing: border-box;
                    line-height: 1.4;
                `;
                warningEl.innerHTML = `
                    <span style="font-size: 1.1em;">⚠️</span>
                    <span><strong>Warning:</strong> Automated moderation actions are not tolerated. Triggering <code>/ban</code> or <code>/kick</code> automatically on events can get your bot/account suspended.</span>
                `;
                parent.appendChild(warningEl);
            }
        } else {
            if (warningEl) {
                warningEl.remove();
            }
        }
    }

    function handleDocumentChange(e) {
        if (e.target) {
            if (e.target.classList.contains('t-custom-eventType')) {
                const card = e.target.closest('.trigger-card');
                if (card) updateTriggerFieldsVisibility(card);
            }
            if (e.target.classList.contains('cmd-custom-commandType')) {
                const row = e.target.closest('.command-row');
                if (row) updateCommandFieldsVisibility(row);
            }
            if (e.target.classList.contains('t-trigger-type') || e.target.classList.contains('cmd-type')) {
                setTimeout(updateAllKickFieldsVisibility, 50);
            }
        }
    }

    function startObservingTriggers() {
        const targetNode = document.getElementById('triggers-container');
        if (!targetNode) return;
        
        // Initial scan
        scanAllInputs();
        updateAllKickFieldsVisibility();

        triggerObserver = new MutationObserver((mutationsList) => {
            scanAllInputs();
            updateAllKickFieldsVisibility();
        });

        triggerObserver.observe(targetNode, { childList: true, subtree: true });
        document.addEventListener('change', handleDocumentChange);
    }

    function stopObservingTriggers() {
        if (triggerObserver) {
            triggerObserver.disconnect();
            triggerObserver = null;
        }
        document.removeEventListener('change', handleDocumentChange);
    }

    function scanAllInputs() {
        const inputs = document.querySelectorAll('.cmd-custom-message');
        inputs.forEach(input => {
            const commandRow = input.closest('.command-row');
            if (commandRow) {
                const typeSelect = commandRow.querySelector('.cmd-type');
                if (typeSelect && typeSelect.value === 'kick_command') {
                    const commandTypeSelect = commandRow.querySelector('.cmd-custom-commandType');
                    if (commandTypeSelect && commandTypeSelect.value === 'send_message') {
                        updateBanWarning(input);
                    }
                }
            }
        });
    }

    function handleKeyDown(e) {
        if (!activeInput) return;
        const menu = document.getElementById("kick-autocomplete-menu");
        if (!menu) return;

        if (e.key === "ArrowDown") {
            e.preventDefault();
            e.stopPropagation();
            activeIndex = (activeIndex + 1) % filteredCommands.length;
            renderMenuContent(menu);
        } else if (e.key === "ArrowUp") {
            e.preventDefault();
            e.stopPropagation();
            activeIndex = (activeIndex - 1 + filteredCommands.length) % filteredCommands.length;
            renderMenuContent(menu);
        } else if (e.key === "Enter" || e.key === "Tab") {
            e.preventDefault();
            e.stopPropagation();
            const selected = filteredCommands[activeIndex];
            if (selected) {
                selectCommand(selected.cmd);
            }
        } else if (e.key === "Escape") {
            e.preventDefault();
            e.stopPropagation();
            hideMenu();
        }
    }

    function handleClick(e) {
        const menu = document.getElementById("kick-autocomplete-menu");
        if (menu && !menu.contains(e.target) && e.target !== activeInput) {
            hideMenu();
        }
    }

    async function refreshAccessToken() {
        const refreshToken = (currentConfig.refresh_token || "").trim();
        const clientId = (currentConfig.client_id || "").trim() || CLIENT_ID;
        const clientSecret = (currentConfig.client_secret || "").trim() || CLIENT_SECRET;
        const googleScriptUrl = (currentConfig.google_script_url || "").trim();

        if (!refreshToken) {
            logMsg("[Kick API Error] Cannot refresh token: Missing Refresh Token.", true);
            return false;
        }

        logMsg("[Kick API] Access token expired or missing. Refreshing tokens...");

        try {
            let response;
            if (googleScriptUrl) {
                logMsg(`[Kick API] Routing refresh through Google Apps Script proxy: ${googleScriptUrl}`);
                response = await fetch(googleScriptUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'text/plain'
                    },
                    body: JSON.stringify({
                        action: 'refresh',
                        refresh_token: refreshToken,
                        client_id: clientId
                    })
                });
            } else {
                const params = new URLSearchParams();
                params.append('grant_type', 'refresh_token');
                params.append('refresh_token', refreshToken);
                params.append('client_id', clientId);
                params.append('client_secret', clientSecret);

                response = await fetch('https://id.kick.com/oauth/token', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: params
                });
            }

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Kick API Error] Token refresh failed: ${response.status} ${response.statusText} - ${errText}`, true);
                return false;
            }

            const data = await response.json();
            if (data.error) {
                logMsg(`[Kick API Error] Proxy refresh returned error: ${data.error_description || data.error}`, true);
                return false;
            }

            if (data.access_token) {
                // Update module config in memory
                currentConfig.access_token = data.access_token;
                currentConfig.refresh_token = data.refresh_token || refreshToken;
                currentConfig.token_expires_at = Date.now() + (data.expires_in * 1000);

                // Persist to window.config
                if (window.config) {
                    if (!window.config.modules) window.config.modules = {};
                    if (!window.config.modules.kick_api) window.config.modules.kick_api = {};
                    
                    window.config.modules.kick_api.client_id = clientId;
                    window.config.modules.kick_api.client_secret = googleScriptUrl ? "" : clientSecret;
                    window.config.modules.kick_api.google_script_url = googleScriptUrl;
                    window.config.modules.kick_api.access_token = currentConfig.access_token;
                    window.config.modules.kick_api.refresh_token = currentConfig.refresh_token;
                    window.config.modules.kick_api.token_expires_at = currentConfig.token_expires_at;
                    if (window.saveConfig) window.saveConfig();
                }

                logMsg("[Kick API] Tokens refreshed successfully!");
                return true;
            }
            return false;
        } catch (err) {
            logMsg(`[Kick API Error] Network error during token refresh: ${err.message} (Make sure your Google Apps Script Web App is deployed with 'Execute as: Me' and 'Who has access: Anyone')`, true);
            return false;
        }
    }

    async function getValidToken() {
        let token = (currentConfig.access_token || "").trim();
        const expiresAt = currentConfig.token_expires_at || 0;
        
        if (!token || Date.now() >= (expiresAt - 60000)) {
            const refreshed = await refreshAccessToken();
            if (refreshed) {
                token = currentConfig.access_token;
            }
        }
        return token;
    }

    // ─── PKCE Generator Helper Functions ────────────────────────────────────
    function base64UrlEncode(bytes) {
        const str = String.fromCharCode(...bytes);
        const base64 = btoa(str);
        return base64
            .replace(/\+/g, '-')
            .replace(/\//g, '_')
            .replace(/=+$/, '');
    }

    function generateCodeVerifier() {
        const array = new Uint8Array(32);
        window.crypto.getRandomValues(array);
        return base64UrlEncode(array);
    }

    async function generateCodeChallenge(verifier) {
        const encoder = new TextEncoder();
        const data = encoder.encode(verifier);
        const digest = await window.crypto.subtle.digest('SHA-256', data);
        return base64UrlEncode(new Uint8Array(digest));
    }

    async function resolveChannelId(slug, token) {
        try {
            const cleanSlug = (slug || "").trim().toLowerCase();
            logMsg(`[Kick API] Resolving IDs for channel "${cleanSlug}"...`);

            let userId = null;
            let channelId = null;
            let chatroomId = null;

            // 1. Try public web API first (provides all three IDs: user_id, channel_id, chatroom_id)
            try {
                const webUrl = `https://kick.com/api/v1/channels/${encodeURIComponent(cleanSlug)}`;
                const webResponse = await fetch(webUrl, {
                    method: "GET",
                    headers: {
                        "Accept": "application/json"
                    }
                });
                if (webResponse.ok) {
                    const webData = await webResponse.json();
                    userId = webData.user_id;
                    channelId = webData.id;
                    if (webData.chatroom) {
                        chatroomId = webData.chatroom.id;
                    }
                    logMsg(`[Kick API] Resolved via Web API: User ID = ${userId}, Channel ID = ${channelId}, Chatroom ID = ${chatroomId}`);
                } else {
                    logMsg(`[Kick API Warning] Web API lookup failed (status ${webResponse.status}). Trying official API fallback...`);
                }
            } catch (err) {
                logMsg(`[Kick API Warning] Web API fetch error: ${err.message}. Trying official API fallback...`);
            }

            // 2. Fall back to official Developer API
            if (!userId) {
                const url = `https://api.kick.com/public/v1/channels?slug=${encodeURIComponent(cleanSlug)}`;
                const response = await fetch(url, {
                    method: "GET",
                    headers: {
                        "Authorization": `Bearer ${token}`,
                        "Accept": "application/json"
                    }
                });
                if (response.ok) {
                    const data = await response.json();
                    if (data.data && data.data.length > 0) {
                        const channelInfo = data.data[0];
                        userId = channelInfo.broadcaster_user_id;
                        
                        // Extract channel ID from banner_picture URL as fallback if possible
                        // Format: https://files.kick.com/images/channel/3395313/banner_image/...
                        if (channelInfo.banner_picture) {
                            const match = channelInfo.banner_picture.match(/\/images\/channel\/(\d+)\//);
                            if (match) {
                                channelId = parseInt(match[1], 10);
                                chatroomId = channelId; // Best guess fallback
                            }
                        }
                        logMsg(`[Kick API] Resolved via Developer API: User ID = ${userId}, Channel ID = ${channelId || 'unknown'}`);
                    }
                } else {
                    const errText = await response.text();
                    logMsg(`[Kick API Error] Fallback Channel ID lookup failed for "${cleanSlug}": ${response.status} - ${errText}`, true);
                }
            }

            if (userId) {
                // Save resolved IDs to configuration memory & persist
                currentConfig.resolved_broadcaster_id = userId;
                currentConfig.resolved_channel_id = channelId || userId;
                currentConfig.resolved_chatroom_id = chatroomId || channelId || userId;
                currentConfig.resolved_broadcaster_username = slug;

                if (window.config && window.config.modules && window.config.modules.kick_api) {
                    window.config.modules.kick_api.resolved_broadcaster_id = userId;
                    window.config.modules.kick_api.resolved_channel_id = channelId || userId;
                    window.config.modules.kick_api.resolved_chatroom_id = chatroomId || channelId || userId;
                    window.config.modules.kick_api.resolved_broadcaster_username = slug;
                    if (window.saveConfig) window.saveConfig();
                }
                return userId;
            }

            logMsg(`[Kick API Error] Could not resolve IDs for "${slug}"`, true);
            return null;
        } catch (e) {
            logMsg(`[Kick API Error] Network error resolving channel ID: ${e.message}`, true);
            return null;
        }
    }

    async function sendKickMessage(msg) {
        const broadcasterSetting = (currentConfig.broadcaster_id || "").trim();
        if (!broadcasterSetting) {
            logMsg("[Kick API Error] Message not sent: Broadcaster setting is missing.", true);
            return;
        }

        // Check if token is expired or close to expiry (within 60 seconds)
        let token = (currentConfig.access_token || "").trim();
        const expiresAt = currentConfig.token_expires_at || 0;
        
        if (!token || Date.now() >= (expiresAt - 60000)) {
            const refreshed = await refreshAccessToken();
            if (!refreshed) {
                logMsg("[Kick API Error] Message not sent: OAuth token refresh failed. Please authorize again.", true);
                return;
            }
            token = currentConfig.access_token;
        }

        let broadcasterUserId = parseInt(broadcasterSetting, 10);
        if (isNaN(broadcasterUserId)) {
            // It is a username. Check cache first.
            if (currentConfig.resolved_broadcaster_id && currentConfig.resolved_broadcaster_username === broadcasterSetting) {
                broadcasterUserId = currentConfig.resolved_broadcaster_id;
            } else {
                logMsg(`[Kick API] Resolving channel ID for username "${broadcasterSetting}"...`);
                const resolved = await resolveChannelId(broadcasterSetting, token);
                if (!resolved) {
                    logMsg(`[Kick API Error] Message not sent: Could not resolve username "${broadcasterSetting}" to a numeric ID.`, true);
                    return;
                }
                broadcasterUserId = resolved;
                currentConfig.resolved_broadcaster_id = resolved;
                currentConfig.resolved_broadcaster_username = broadcasterSetting;
                
                // Persist the resolved data
                if (window.config && window.config.modules && window.config.modules.kick_api) {
                    window.config.modules.kick_api.resolved_broadcaster_id = resolved;
                    window.config.modules.kick_api.resolved_broadcaster_username = broadcasterSetting;
                    if (window.saveConfig) window.saveConfig();
                }
            }
        }

        logMsg(`[Kick API] Sending message to Kick room (User ID: ${broadcasterUserId}): ${msg}...`);

        try {
            const response = await fetch("https://api.kick.com/public/v1/chat", {
                method: "POST",
                headers: {
                    "Authorization": `Bearer ${token}`,
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    broadcaster_user_id: broadcasterUserId,
                    content: msg,
                    type: "user"
                })
            });

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Kick API Error] Failed to send message: ${response.status} ${response.statusText} - ${errText}`, true);
            } else {
                logMsg(`[Kick API] Sent message successfully: ${msg}`);
            }
        } catch (err) {
            logMsg(`[Kick API Error] Network error sending message: ${err.message}`, true);
        }
    }

    async function resolveKickCategoryId(categoryNameOrId) {
        if (!categoryNameOrId) return 0;
        const trimmed = String(categoryNameOrId).trim();
        // If it looks like a numeric ID already, return it directly
        if (/^\d+$/.test(trimmed)) {
            return parseInt(trimmed, 10);
        }

        let token = (currentConfig.access_token || "").trim();
        const expiresAt = currentConfig.token_expires_at || 0;
        
        if (!token || Date.now() >= (expiresAt - 60000)) {
            const refreshed = await refreshAccessToken();
            if (!refreshed) {
                logMsg("[Kick API Error] OAuth token refresh failed while resolving category.", true);
                return 0;
            }
            token = currentConfig.access_token;
        }

        try {
            const url = `https://api.kick.com/public/v2/categories?q=${encodeURIComponent(trimmed)}`;
            const response = await fetch(url, {
                method: "GET",
                headers: {
                    "Authorization": `Bearer ${token}`,
                    "Accept": "application/json"
                }
            });
            if (response.ok) {
                const resData = await response.json();
                if (resData && resData.data && resData.data.categories && resData.data.categories.length > 0) {
                    // Try to find exact match case-insensitive
                    const match = resData.data.categories.find(c => c.name.toLowerCase() === trimmed.toLowerCase()) || resData.data.categories[0];
                    return match.id;
                }
            }
        } catch (e) {
            logMsg(`[Kick API Warning] Failed to resolve category name "${trimmed}": ${e.message}`);
        }
        return 0;
    }

    async function updateKickStreamInfo(title, categoryNameOrId, fallbackCategory = "none") {
        let token = (currentConfig.access_token || "").trim();
        const expiresAt = currentConfig.token_expires_at || 0;
        
        if (!token || Date.now() >= (expiresAt - 60000)) {
            const refreshed = await refreshAccessToken();
            if (!refreshed) {
                logMsg("[Kick API Error] Could not update stream info: OAuth token refresh failed.", true);
                return;
            }
            token = currentConfig.access_token;
        }

        let categoryId = 0;
        if (categoryNameOrId) {
            categoryId = await resolveKickCategoryId(categoryNameOrId);
            if (!categoryId) {
                logMsg(`[Kick API Warning] Could not resolve category "${categoryNameOrId}" to a valid ID.`);
                if (fallbackCategory && fallbackCategory !== "none") {
                    logMsg(`[Kick API] Attempting to resolve fallback category "${fallbackCategory}"...`);
                    categoryId = await resolveKickCategoryId(fallbackCategory);
                }
            }
        } else if (fallbackCategory && fallbackCategory !== "none") {
            logMsg(`[Kick API] Category input was blank. Resolving fallback category "${fallbackCategory}"...`);
            categoryId = await resolveKickCategoryId(fallbackCategory);
        }

        logMsg(`[Kick API] Updating stream info (Title: "${title}", Category ID: ${categoryId || 'none'})...`);

        try {
            const body = {};
            if (title) body.session_title = title;
            if (categoryId) body.category_id = categoryId;

            const response = await fetch("https://api.kick.com/public/v1/channels", {
                method: "PATCH",
                headers: {
                    "Authorization": `Bearer ${token}`,
                    "Content-Type": "application/json",
                    "Accept": "application/json"
                },
                body: JSON.stringify(body)
            });

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Kick API Error] Failed to update stream info: ${response.status} ${response.statusText} - ${errText}`, true);
            } else {
                logMsg(`[Kick API] Updated stream info successfully!`);
            }
        } catch (err) {
            logMsg(`[Kick API Error] Network error updating stream info: ${err.message}`, true);
        }
    }

    async function banKickUser(targetUsername, duration = null, reason = "") {
        let token = (currentConfig.access_token || "").trim();
        const expiresAt = currentConfig.token_expires_at || 0;
        
        if (!token || Date.now() >= (expiresAt - 60000)) {
            const refreshed = await refreshAccessToken();
            if (!refreshed) {
                logMsg("[Kick API Error] Could not moderate user: OAuth token refresh failed.", true);
                return;
            }
            token = currentConfig.access_token;
        }

        const broadcasterSetting = (currentConfig.broadcaster_id || "").trim();
        let broadcasterUserId = parseInt(broadcasterSetting, 10);
        if (isNaN(broadcasterUserId)) {
            broadcasterUserId = currentConfig.resolved_broadcaster_id || 0;
        }

        if (!broadcasterUserId) {
            logMsg("[Kick API Error] Cannot moderate user: Broadcaster User ID not resolved yet.", true);
            return;
        }

        logMsg(`[Kick API] Resolving ID for target user "${targetUsername}"...`);
        const targetUserId = await resolveChannelId(targetUsername, token);
        if (!targetUserId) {
            logMsg(`[Kick API Error] Could not resolve target username "${targetUsername}" to a numeric ID.`, true);
            return;
        }

        const url = "https://api.kick.com/public/v1/moderation/bans";
        const body = {
            broadcaster_user_id: broadcasterUserId,
            user_id: targetUserId,
            reason: reason || "Moderated by bot"
        };
        if (duration !== null && duration > 0) {
            body.duration = Math.max(1, Math.min(10080, Math.ceil(duration / 60)));
        }

        logMsg(`[Kick API] Sending ban/timeout request to Kick: ${JSON.stringify(body)}...`);

        try {
            const response = await fetch(url, {
                method: "POST",
                headers: {
                    "Authorization": `Bearer ${token}`,
                    "Content-Type": "application/json",
                    "Accept": "application/json"
                },
                body: JSON.stringify(body)
            });

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Kick API Error] Moderation action failed: ${response.status} ${response.statusText} - ${errText}`, true);
            } else {
                logMsg(`[Kick API] Moderation action successful!`);
            }
        } catch (err) {
            logMsg(`[Kick API Error] Network error during moderation request: ${err.message}`, true);
        }
    }

    async function unbanKickUser(targetUsername) {
        let token = (currentConfig.access_token || "").trim();
        const expiresAt = currentConfig.token_expires_at || 0;
        
        if (!token || Date.now() >= (expiresAt - 60000)) {
            const refreshed = await refreshAccessToken();
            if (!refreshed) {
                logMsg("[Kick API Error] Could not unban user: OAuth token refresh failed.", true);
                return;
            }
            token = currentConfig.access_token;
        }

        const broadcasterSetting = (currentConfig.broadcaster_id || "").trim();
        let broadcasterUserId = parseInt(broadcasterSetting, 10);
        if (isNaN(broadcasterUserId)) {
            broadcasterUserId = currentConfig.resolved_broadcaster_id || 0;
        }

        if (!broadcasterUserId) {
            logMsg("[Kick API Error] Cannot unban user: Broadcaster User ID not resolved yet.", true);
            return;
        }

        logMsg(`[Kick API] Resolving ID for target user "${targetUsername}"...`);
        const targetUserId = await resolveChannelId(targetUsername, token);
        if (!targetUserId) {
            logMsg(`[Kick API Error] Could not resolve target username "${targetUsername}" to a numeric ID.`, true);
            return;
        }

        const url = "https://api.kick.com/public/v1/moderation/bans";
        const body = {
            broadcaster_user_id: broadcasterUserId,
            user_id: targetUserId
        };

        logMsg(`[Kick API] Sending unban request to Kick: ${JSON.stringify(body)}...`);

        try {
            const response = await fetch(url, {
                method: "DELETE",
                headers: {
                    "Authorization": `Bearer ${token}`,
                    "Content-Type": "application/json",
                    "Accept": "application/json"
                },
                body: JSON.stringify(body)
            });

            if (!response.ok) {
                const errText = await response.text();
                logMsg(`[Kick API Error] Unban failed: ${response.status} ${response.statusText} - ${errText}`, true);
            } else {
                logMsg(`[Kick API] Unban successful!`);
            }
        } catch (err) {
            logMsg(`[Kick API Error] Network error during unban request: ${err.message}`, true);
        }
    }

    function replaceTemplateVariables(text, matches, payload) {
        let result = text || "";
        
        if (matches && Array.isArray(matches)) {
            matches.forEach((val, idx) => {
                result = result.replace(new RegExp(`\\{${idx + 1}\\}`, 'g'), val !== undefined ? val : "");
            });
        }
        
        if (!payload) return result;

        return result.replace(/\{([a-zA-Z0-9_\.\[\]]+)(?:\s*\|\s*([^}]+))?\}/g, (match, path, fallback) => {
            let val = getNestedValue(payload, path);
            if (val === undefined && payload.customData) {
                val = getNestedValue(payload.customData, path);
            }
            if (val !== undefined && val !== null && typeof val !== 'object') {
                return val;
            }
            if (fallback !== undefined) {
                return fallback.trim();
            }
            const rootKey = path.split('.')[0].replace(/\[\d+\]/g, '');
            if (payload[rootKey] !== undefined || (payload.customData && payload.customData[rootKey] !== undefined)) {
                return "";
            }
            return match;
        });
    }

    function getNestedValue(obj, path) {
        if (obj === null || obj === undefined) return undefined;
        const cleanPath = path.replace(/\[(\d+)\]/g, '.$1');
        return cleanPath.split('.').reduce((acc, part) => {
            return (acc && acc[part] !== undefined) ? acc[part] : undefined;
        }, obj);
    }

    // Register Unified Outbound Action/Command
    window.TheaterController.registerCommand("kick_command", async (inputs, matches, payload) => {
        const commandType = inputs.commandType || "send_message";
        const resolve = (txt) => {
            if (!txt) return "";
            return window.TheaterController.replaceVariables ?
                window.TheaterController.replaceVariables(txt, matches, payload) :
                replaceTemplateVariables(txt, matches, payload);
        };

        if (commandType === 'send_message') {
            const textTemplate = inputs.message || "";
            if (textTemplate) {
                sendKickMessage(resolve(textTemplate));
            }
        } else if (commandType === 'ban_user') {
            const target = resolve(inputs.targetUser);
            const reason = resolve(inputs.reason);
            if (target) {
                banKickUser(target, null, reason);
            }
        } else if (commandType === 'timeout_user') {
            const target = resolve(inputs.targetUser);
            const duration = inputs.duration !== undefined ? parseInt(inputs.duration, 10) : 600;
            const reason = resolve(inputs.reason);
            if (target) {
                banKickUser(target, duration, reason);
            }
        } else if (commandType === 'unban_user') {
            const target = resolve(inputs.targetUser);
            if (target) {
                unbanKickUser(target);
            }
        } else if (commandType === 'clear_chat') {
            logMsg(`[Kick API Warning] Kick does not expose an official clear chat endpoint. Sending "/clear" to chat (requires moderator/owner bot permission)...`);
            sendKickMessage("/clear");
        } else if (commandType === 'add_moderator') {
            const target = resolve(inputs.targetUser);
            if (target) sendKickMessage(`/mod ${target}`);
        } else if (commandType === 'remove_moderator') {
            const target = resolve(inputs.targetUser);
            if (target) sendKickMessage(`/unmod ${target}`);
        } else if (commandType === 'add_vip') {
            const target = resolve(inputs.targetUser);
            if (target) sendKickMessage(`/og ${target}`);
        } else if (commandType === 'remove_vip') {
            const target = resolve(inputs.targetUser);
            if (target) sendKickMessage(`/unog ${target}`);
        } else if (commandType === 'slow_mode') {
            const seconds = inputs.seconds !== undefined ? parseInt(inputs.seconds, 10) : 10;
            if (seconds <= 0) {
                sendKickMessage("/slow off");
            } else {
                sendKickMessage(`/slow ${seconds}`);
            }
        } else if (commandType === 'follower_only') {
            const minutes = inputs.minutes !== undefined ? parseInt(inputs.minutes, 10) : 10;
            if (minutes <= 0) {
                sendKickMessage("/followonly off");
            } else {
                sendKickMessage(`/followonly ${minutes}`);
            }
        } else if (commandType === 'subscriber_only') {
            const enabled = inputs.enabled || "on";
            if (enabled === "off") {
                sendKickMessage("/subonly off");
            } else {
                sendKickMessage("/subonly");
            }
        } else if (commandType === 'emote_only') {
            const enabled = inputs.enabled || "on";
            if (enabled === "off") {
                sendKickMessage("/emoteonly off");
            } else {
                sendKickMessage("/emoteonly");
            }
        } else if (commandType === 'pin_message') {
            const messageId = resolve(inputs.messageId);
            if (messageId) {
                sendKickMessage(`/pin ${messageId}`);
            } else {
                sendKickMessage("/pin");
            }
        } else if (commandType === 'unpin_message') {
            sendKickMessage("/unpin");
        } else if (commandType === 'update_stream') {
            const title = resolve(inputs.title);
            const categoryId = inputs.categoryId !== undefined ? resolve(inputs.categoryId) : "";
            const fallbackCategory = inputs.fallbackCategory || "none";
            updateKickStreamInfo(title, categoryId, fallbackCategory);
        }
    }, {
        label: "Kick: Action / Command",
        fields: [
            {
                id: "commandType",
                label: "Kick Command Type",
                type: "select",
                options: [
                    { value: "send_message", label: "Send Chat Message" },
                    { value: "ban_user", label: "Ban User" },
                    { value: "timeout_user", label: "Timeout User" },
                    { value: "unban_user", label: "Unban User" },
                    { value: "clear_chat", label: "Clear Chat" },
                    { value: "add_moderator", label: "Add Moderator (/mod)" },
                    { value: "remove_moderator", label: "Remove Moderator (/unmod)" },
                    { value: "add_vip", label: "Add VIP (/og)" },
                    { value: "remove_vip", label: "Remove VIP (/unog)" },
                    { value: "slow_mode", label: "Set Slow Mode" },
                    { value: "follower_only", label: "Set Follower Only Mode" },
                    { value: "subscriber_only", label: "Set Subscriber Only Mode" },
                    { value: "emote_only", label: "Set Emote Only Mode" },
                    { value: "pin_message", label: "Pin Message (/pin)" },
                    { value: "unpin_message", label: "Unpin Message (/unpin)" },
                    { value: "update_stream", label: "Update Stream Metadata" }
                ],
                default: "send_message"
            },
            {
                id: "message",
                label: "Message Text (supports {username}, wildcards {1}, or custom event data)",
                type: "text",
                default: "Thanks for the support {username}!",
                style: "grid-column: 1 / -1;"
            },
            {
                id: "targetUser",
                label: "Target Username",
                type: "text",
                default: "{username}"
            },
            {
                id: "reason",
                label: "Reason (optional)",
                type: "text",
                default: "Automated moderation"
            },
            {
                id: "duration",
                label: "Timeout Duration (seconds)",
                type: "number",
                default: 600
            },
            {
                id: "seconds",
                label: "Slow duration in seconds (0 to turn off)",
                type: "number",
                default: 10
            },
            {
                id: "minutes",
                label: "Follow duration in minutes (0 to turn off)",
                type: "number",
                default: 10
            },
            {
                id: "enabled",
                label: "Status",
                type: "select",
                options: [
                    { value: "on", label: "Enabled (On)" },
                    { value: "off", label: "Disabled (Off)" }
                ],
                default: "on"
            },
            {
                id: "messageId",
                label: "Message ID to Pin (optional)",
                type: "text",
                default: "{id}"
            },
            {
                id: "title",
                label: "Stream Title",
                type: "text",
                default: "",
                style: "grid-column: 1 / -1;"
            },
            {
                id: "categoryId",
                label: "Stream Category Name or ID",
                type: "text",
                default: ""
            },
            {
                id: "fallbackCategory",
                label: "Non-Gaming Category Fallback (if game not found)",
                type: "select",
                options: [
                    { value: "none", label: "No Fallback (Skip category update)" },
                    { value: "Just Chatting", label: "Just Chatting" },
                    { value: "IRL", label: "IRL" },
                    { value: "Music", label: "Music" },
                    { value: "Art", label: "Art" },
                    { value: "Creative", label: "Creative" },
                    { value: "VTuber", label: "VTuber" },
                    { value: "Watch Parties", label: "Watch Parties" },
                    { value: "Talk Shows & Podcasts", label: "Talk Shows & Podcasts" },
                    { value: "ASMR", label: "ASMR" }
                ],
                default: "none"
            }
        ]
    }, MODULE_ID);


    // ─── Kick WebSocket Event Capture & Custom Trigger ─────────────────────────
    let kickWS = null;
    let kickIsConnected = false;
    let kickReconnectTimer = null;

    async function initChatConnection() {
        const broadcaster = (currentConfig.broadcaster_id || "").trim();
        if (!broadcaster) {
            logMsg("[Kick API] Broadcaster username not configured. Chat triggers will not be active.");
            return;
        }

        if (currentConfig.resolved_broadcaster_id && 
            currentConfig.resolved_channel_id && 
            currentConfig.resolved_chatroom_id && 
            currentConfig.resolved_broadcaster_username === broadcaster) {
            connectKickChat();
            return;
        }

        let token = (currentConfig.access_token || "").trim();
        logMsg(`[Kick API] Resolving channel ID for "${broadcaster}" on startup...`);
        const id = await resolveChannelId(broadcaster, token);
        if (id) {
            connectKickChat();
        } else {
            logMsg("[Kick API Error] Could not resolve channel ID. Chat triggers will not be active.", true);
        }
    }

    function connectKickChat() {
        disconnectKickChat();

        const broadcasterUserId = currentConfig.resolved_broadcaster_id;
        const channelId = currentConfig.resolved_channel_id || broadcasterUserId;
        const chatroomId = currentConfig.resolved_chatroom_id || channelId || broadcasterUserId;

        if (!broadcasterUserId) {
            logMsg("[Kick API Error] Cannot connect to chat WebSocket: Broadcaster User ID not resolved yet.", true);
            return;
        }

        logMsg(`[Kick API] Connecting to Kick Chat Pusher for Chatroom #${chatroomId} (Channel #${channelId})...`);

        try {
            kickWS = new WebSocket("wss://ws-us2.pusher.com/app/32cbd69e4b950bf97679?protocol=7&client=js&version=7.4.0&flash=false");
        } catch (e) {
            logMsg(`[Kick API Error] Failed to create Kick WebSocket connection: ${e.message}`, true);
            scheduleKickReconnect();
            return;
        }

        kickWS.onopen = () => {
            logMsg("[Kick API] Connected to Kick Pusher WebSocket. Subscribing to chatroom and channel...");
            
            // Subscribe to Chatroom
            kickWS.send(JSON.stringify({
                event: "pusher:subscribe",
                data: {
                    auth: "",
                    channel: `chatrooms.${chatroomId}.v2`
                }
            }));

            // Subscribe to Channel (Followers, Hosts, etc.)
            kickWS.send(JSON.stringify({
                event: "pusher:subscribe",
                data: {
                    auth: "",
                    channel: `channel.${channelId}`
                }
            }));

            kickIsConnected = true;
        };

        kickWS.onmessage = (event) => {
            try {
                const data = JSON.parse(event.data);
                
                // Pusher ping/pong keep-alive
                if (data.event === "pusher:ping") {
                    kickWS.send(JSON.stringify({ event: "pusher:pong" }));
                    return;
                }

                if (data.event !== "pusher:pong") {
                    logMsg(`[Kick WS Debug] Event: ${data.event} | Channel: ${data.channel || 'none'}`);
                }

                const payloadData = typeof data.data === "string" ? JSON.parse(data.data) : data.data;

                if (data.event === "pusher:error") {
                    const errPayload = payloadData || data.data;
                    logMsg(`[Kick WS Error Details] ${typeof errPayload === 'object' ? JSON.stringify(errPayload) : errPayload}`, true);
                }

                if (data.event.startsWith("pusher:")) {
                    return;
                }

                if (data.event === "App\\Events\\ChatMessageEvent" || data.event === "App\\Events\\ChatMessageSentEvent") {
                    handleKickChatMessage(payloadData);
                } else if (data.event === "App\\Events\\SubscriptionEvent") {
                    handleKickSubscription(payloadData);
                } else if (data.event === "App\\Events\\GiftedSubscriptionsEvent") {
                    handleKickGiftedSubscription(payloadData);
                } else if (data.event === "App\\Events\\UserBannedEvent" || data.event === "App\\Events\\UserBanned") {
                    handleKickUserBanned(payloadData);
                } else if (data.event === "App\\Events\\UserUnbannedEvent" || data.event === "App\\Events\\UserUnbanned") {
                    handleKickUserUnbanned(payloadData);
                } else if (data.event === "App\\Events\\MessageDeletedEvent" || data.event === "App\\Events\\ChatMessageDeletedEvent") {
                    handleKickMessageDeleted(payloadData);
                } else if (data.event === "App\\Events\\PinnedMessageCreatedEvent") {
                    handleKickPinnedMessage(payloadData);
                } else if (data.event === "App\\Events\\PinnedMessageDeletedEvent") {
                    handleKickPinnedMessageDeleted(payloadData);
                } else if (data.event === "App\\Events\\ChatroomClearEvent") {
                    handleKickChatroomCleared(payloadData);
                } else if (data.event === "App\\Events\\PollUpdateEvent" || data.event === "App\\Events\\PollDeleteEvent") {
                    handleKickPollUpdated(payloadData);
                } else if (data.event === "App\\Events\\FollowersUpdateEvent" || data.event === "FollowersUpdateEvent") {
                    handleKickFollowersUpdate(payloadData);
                } else if (data.event === "App\\Events\\StreamHostEvent" || data.event === "StreamHostEvent" || data.event === "App\\Events\\StreamerAlertEvent") {
                    handleKickStreamHost(payloadData);
                } else {
                    handleGenericKickEvent(data.event, payloadData);
                }
            } catch (err) {
                // Ignore parsing errors for other non-JSON events
            }
        };

        kickWS.onerror = (err) => {
            logMsg("[Kick API Error] Kick WebSocket error occurred.", true);
        };

        kickWS.onclose = () => {
            kickIsConnected = false;
            logMsg("[Kick API] Kick WebSocket connection closed.");
            scheduleKickReconnect();
        };
    }

    function disconnectKickChat() {
        clearTimeout(kickReconnectTimer);
        kickReconnectTimer = null;
        if (kickWS) {
            kickWS.onopen = null;
            kickWS.onmessage = null;
            kickWS.onerror = null;
            kickWS.onclose = null;
            if (kickWS.readyState === WebSocket.OPEN || kickWS.readyState === WebSocket.CONNECTING) {
                kickWS.close();
            }
            kickWS = null;
        }
        kickIsConnected = false;
    }

    function scheduleKickReconnect() {
        clearTimeout(kickReconnectTimer);
        kickReconnectTimer = setTimeout(() => {
            logMsg("[Kick API] Reconnecting to Kick chat...");
            connectKickChat();
        }, 10000);
    }

    function handleKickChatMessage(data) {
        const messageText = data.content || "";
        const senderName = (data.sender && data.sender.username) ? data.sender.username : "Anonymous";
        
        let isSubscriber = false;
        let isModerator = false;
        
        if (data.sender && data.sender.identity && Array.isArray(data.sender.identity.badges)) {
            data.sender.identity.badges.forEach(badge => {
                if (badge.type === "subscriber") isSubscriber = true;
                if (badge.type === "moderator" || badge.type === "broadcaster") isModerator = true;
            });
        }

        logMsg(`[Kick API] ${senderName}: ${messageText}`);

        const payload = {
            username: senderName,
            message: messageText,
            customData: {
                subscriber: isSubscriber,
                moderator: isModerator,
                id: data.id,
                chatroom_id: data.chatroom_id,
                created_at: data.created_at
            }
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "message",
                message: messageText,
                username: senderName,
                subscriber: isSubscriber,
                moderator: isModerator
            }, payload);
        }
    }

    function handleKickSubscription(data) {
        const subscriberName = data.username || "Anonymous";
        const months = parseInt(data.months || 1, 10);
        logMsg(`[Kick API] Subscription Event: ${subscriberName} subscribed for ${months} months!`);

        const payload = {
            username: subscriberName,
            message: `Subscribed for ${months} months`,
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "subscription",
                username: subscriberName,
                months: months
            }, payload);
        }
    }

    function handleKickGiftedSubscription(data) {
        const gifterName = data.username || "Anonymous";
        const count = parseInt(data.giftCount || 1, 10);
        logMsg(`[Kick API] Gifted Subscriptions Event: ${gifterName} gifted ${count} subscriptions!`);

        const payload = {
            username: gifterName,
            message: `Gifted ${count} subscriptions`,
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "gifted_subscription",
                username: gifterName,
                giftCount: count
            }, payload);
        }
    }

    function handleKickUserBanned(data) {
        const username = (data.user && data.user.username) ? data.user.username : "Unknown User";
        const bannedBy = (data.banned_by && data.banned_by.username) ? data.banned_by.username : "System";
        const reason = data.reason || "";
        logMsg(`[Kick Moderation] User banned: ${username} by ${bannedBy}. Reason: ${reason}`);

        const payload = {
            username: username,
            message: `Banned by ${bannedBy}: ${reason}`,
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "user_banned",
                username: username,
                banned_by: bannedBy,
                reason: reason
            }, payload);
        }
    }

    function handleKickUserUnbanned(data) {
        const username = (data.user && data.user.username) ? data.user.username : "Unknown User";
        const unbannedBy = (data.unbanned_by && data.unbanned_by.username) ? data.unbanned_by.username : "System";
        logMsg(`[Kick Moderation] User unbanned: ${username} by ${unbannedBy}`);

        const payload = {
            username: username,
            message: `Unbanned by ${unbannedBy}`,
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "user_unbanned",
                username: username,
                unbanned_by: unbannedBy
            }, payload);
        }
    }

    function handleKickMessageDeleted(data) {
        const messageId = data.message ? data.message.id : (data.id || "Unknown");
        logMsg(`[Kick API] Message deleted (ID: ${messageId})`);

        const payload = {
            username: "System",
            message: `Message ${messageId} deleted`,
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "message_deleted",
                messageId: messageId
            }, payload);
        }
    }

    function handleKickPinnedMessage(data) {
        const content = (data.message && data.message.content) ? data.message.content : "";
        const sender = (data.message && data.message.sender) ? data.message.sender.username : "System";
        logMsg(`[Kick API] Message pinned: "${content}" by ${sender}`);

        const payload = {
            username: sender,
            message: content,
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "pinned_message",
                message: content,
                username: sender
            }, payload);
        }
    }

    // Handles unpinned messages as well
    function handleKickPinnedMessageDeleted(data) {
        logMsg(`[Kick API] Pinned message deleted.`);

        const payload = {
            username: "System",
            message: "Pinned message deleted",
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "pinned_message_deleted"
            }, payload);
        }
    }

    // Handles chat cleared
    function handleKickChatroomCleared(data) {
        logMsg(`[Kick Moderation] Chat cleared.`);

        const payload = {
            username: "System",
            message: "Chat cleared",
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "chat_cleared"
            }, payload);
        }
    }

    function handleKickPollUpdated(data) {
        const title = (data.poll && data.poll.title) ? data.poll.title : "Active Poll";
        logMsg(`[Kick Events] Poll updated: "${title}"`);

        const payload = {
            username: "System",
            message: `Poll updated: ${title}`,
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "poll_updated",
                title: title
            }, payload);
        }
    }

    function handleKickFollowersUpdate(data) {
        const username = data.username || data.follower || "Anonymous";
        logMsg(`[Kick Events] New follower: ${username}`);

        const payload = {
            username: username,
            message: `${username} followed the channel`,
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "follower",
                username: username
            }, payload);
        }
    }

    function handleKickStreamHost(data) {
        const hoster = data.hoster || "Anonymous";
        const hosted = data.hosted_channel || "";
        logMsg(`[Kick Events] Stream hosted by ${hoster}`);

        const payload = {
            username: hoster,
            message: `${hoster} hosted your stream`,
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: "host",
                username: hoster,
                hosted_channel: hosted
            }, payload);
        }
    }

    function handleGenericKickEvent(eventName, data) {
        logMsg(`[Kick API] Generic Event (${eventName}): ${JSON.stringify(data)}`);
        const payload = {
            username: "Kick",
            message: eventName,
            customData: data
        };

        if (window.TheaterController && window.TheaterController.dispatchTrigger) {
            window.TheaterController.dispatchTrigger("kick_event", {
                eventType: eventName,
                data: data
            }, payload);
        }
    }

    // Visibility control helpers for Kick Event and Kick Command
    function updateTriggerFieldsVisibility(card) {
        const typeSelect = card.querySelector('.t-trigger-type');
        if (!typeSelect || typeSelect.value !== 'kick_event') return;

        const eventTypeSelect = card.querySelector('.t-custom-eventType');
        if (!eventTypeSelect) return;

        const eventType = eventTypeSelect.value;

        // Fields to show/hide
        const fields = {
            messageContains: eventType === 'message',
            exactMatch: eventType === 'message',
            isCommand: eventType === 'message',
            minMonths: eventType === 'subscription',
            minGiftCount: eventType === 'gifted_subscription',
            reasonContains: eventType === 'user_banned'
        };

        for (const [fieldId, shouldShow] of Object.entries(fields)) {
            const el = card.querySelector(`.t-custom-${fieldId}`);
            if (el) {
                const parent = el.closest('div');
                if (parent) {
                    parent.style.display = shouldShow ? 'block' : 'none';
                }
            }
        }
    }

    function updateCommandFieldsVisibility(row) {
        const typeSelect = row.querySelector('.cmd-type');
        if (!typeSelect || typeSelect.value !== 'kick_command') return;

        const commandTypeSelect = row.querySelector('.cmd-custom-commandType');
        if (!commandTypeSelect) return;

        const commandType = commandTypeSelect.value;

        // Fields to show/hide
        const fields = {
            message: commandType === 'send_message',
            targetUser: ['ban_user', 'timeout_user', 'unban_user', 'add_moderator', 'remove_moderator', 'add_vip', 'remove_vip'].includes(commandType),
            reason: ['ban_user', 'timeout_user'].includes(commandType),
            duration: commandType === 'timeout_user',
            seconds: commandType === 'slow_mode',
            minutes: commandType === 'follower_only',
            enabled: ['subscriber_only', 'emote_only'].includes(commandType),
            messageId: commandType === 'pin_message',
            title: commandType === 'update_stream',
            categoryId: commandType === 'update_stream',
            fallbackCategory: commandType === 'update_stream'
        };

        for (const [fieldId, shouldShow] of Object.entries(fields)) {
            const el = row.querySelector(`.cmd-custom-${fieldId}`);
            if (el) {
                const parent = el.closest('div');
                if (parent) {
                    parent.style.display = shouldShow ? 'block' : 'none';
                }
            }
        }
    }

    function updateAllKickFieldsVisibility() {
        document.querySelectorAll('.trigger-card').forEach(card => {
            updateTriggerFieldsVisibility(card);
            card.querySelectorAll('.command-row').forEach(row => {
                updateCommandFieldsVisibility(row);
            });
        });
    }

    // Register Custom Unified Trigger
    window.TheaterController.registerTrigger("kick_event", 
        // Matcher function
        (t, eventData) => {
            const selectedEventType = t.eventType || "message";
            if (selectedEventType !== eventData.eventType) return false;

            if (selectedEventType === "message") {
                const msg = (eventData.message || "").trim();
                if (t.messageContains) {
                    const sub = t.messageContains.trim().toLowerCase();
                    if (!msg.toLowerCase().includes(sub)) return false;
                }
                if (t.exactMatch) {
                    const exact = t.exactMatch.trim().toLowerCase();
                    if (msg.toLowerCase() !== exact) return false;
                }
                if (t.isCommand) {
                    const cmd = t.isCommand.trim().toLowerCase();
                    if (!msg.toLowerCase().startsWith(cmd)) return false;
                }
            } else if (selectedEventType === "subscription") {
                const months = parseInt(eventData.months || 1, 10);
                const minMonths = parseInt(t.minMonths || 1, 10);
                if (months < minMonths) return false;
            } else if (selectedEventType === "gifted_subscription") {
                const count = parseInt(eventData.giftCount || 1, 10);
                const minCount = parseInt(t.minGiftCount || 1, 10);
                if (count < minCount) return false;
            } else if (selectedEventType === "user_banned") {
                if (t.reasonContains) {
                    const reason = (eventData.reason || "").trim().toLowerCase();
                    const match = t.reasonContains.trim().toLowerCase();
                    if (!reason.includes(match)) return false;
                }
            }
            return true;
        },
        // UI Configuration
        {
            label: "Kick: Event Received",
            fields: [
                {
                    id: "eventType",
                    label: "Kick Event Type",
                    type: "select",
                    options: [
                        { value: "message", label: "Chat Message Sent" },
                        { value: "subscription", label: "New / Re-Subscription" },
                        { value: "gifted_subscription", label: "Gifted Subscription" },
                        { value: "follower", label: "New Follower" },
                        { value: "host", label: "Channel Hosted / Raided" },
                        { value: "user_banned", label: "User Banned" },
                        { value: "user_unbanned", label: "User Unbanned" },
                        { value: "message_deleted", label: "Message Deleted" },
                        { value: "pinned_message", label: "Pinned Message" },
                        { value: "pinned_message_deleted", label: "Pinned Message Deleted" },
                        { value: "chat_cleared", label: "Chat Cleared" },
                        { value: "poll_updated", label: "Poll Updated" }
                    ],
                    default: "message"
                },
                {
                    id: "messageContains",
                    label: "Message Contains (optional)",
                    type: "text",
                    default: "",
                    flexBasis: "100%"
                },
                {
                    id: "exactMatch",
                    label: "Exact Match (optional)",
                    type: "text",
                    default: "",
                    flexBasis: "100%"
                },
                {
                    id: "isCommand",
                    label: "Starts With Command (optional, e.g. !play)",
                    type: "text",
                    default: "",
                    flexBasis: "100%"
                },
                {
                    id: "minMonths",
                    label: "Minimum Months",
                    type: "number",
                    default: 1
                },
                {
                    id: "minGiftCount",
                    label: "Minimum Gifted Count",
                    type: "number",
                    default: 1
                },
                {
                    id: "reasonContains",
                    label: "Reason Contains (optional)",
                    type: "text",
                    default: ""
                }
            ]
        },
        MODULE_ID
    );

    // Register Context Providers for Kick API
    if (window.TheaterController.registerContextProvider) {
        window.TheaterController.registerContextProvider("kick_channel_info", async (inputs, payload) => {
            const resolve = (txt) => {
                return window.TheaterController.replaceVariables ?
                    window.TheaterController.replaceVariables(txt, [], payload) :
                    replaceTemplateVariables(txt, [], payload);
            };
            const username = resolve(inputs.username || "{username}");
            if (!username) throw new Error("No username specified");

            const cleanSlug = username.trim().toLowerCase();

            // Try public web API first (CORS bypass/no token required)
            try {
                const webUrl = `https://kick.com/api/v1/channels/${encodeURIComponent(cleanSlug)}`;
                const webResponse = await fetch(webUrl, {
                    method: "GET",
                    headers: {
                        "Accept": "application/json"
                    }
                });
                if (webResponse.ok) {
                    const webData = await webResponse.json();
                    if (webData) return { kick_channel: webData };
                }
            } catch (err) {
                // Ignore web API error, fall back to official API
            }

            // Fall back to official Developer API
            const token = await getValidToken();
            if (!token) throw new Error("Missing Kick token");

            const url = `https://api.kick.com/public/v1/channels?slug=${encodeURIComponent(cleanSlug)}`;
            const response = await fetch(url, {
                method: "GET",
                headers: {
                    "Authorization": `Bearer ${token}`,
                    "Accept": "application/json"
                }
            });
            if (!response.ok) {
                const text = await response.text();
                throw new Error(`Kick API error: ${response.status} - ${text}`);
            }
            const data = await response.json();
            
            let formattedData = {};
            if (data.data && data.data.length > 0) {
                formattedData = data.data[0];
            } else {
                formattedData = data;
            }
            return { kick_channel: formattedData };
        }, {
            label: "Kick: Get Channel Info",
            fields: [
                { id: "username", label: "Broadcaster username to check", type: "text", default: "{username}" }
            ],
            samplePayload: {
                "kick_channel": {
                    "id": 1234567,
                    "user_id": 987654,
                    "slug": "kickdev",
                    "is_banned": false,
                    "playback_url": "https://stream.kick.com/kickdev",
                    "name_username": "KickDev",
                    "user": {
                        "id": 987654,
                        "username": "kickdev",
                        "profile_pic": "https://files.kick.com/images/user/987654/profile_image.png"
                    },
                    "chatroom": {
                        "id": 112233,
                        "chat_mode_old": "public",
                        "subscription_enabled": true,
                        "followers_only": false
                    },
                    "livestream": {
                        "id": 998877,
                        "slug": "kickdev-live",
                        "channel_id": 1234567,
                        "title": "Building awesome interactive streams!",
                        "viewers": 150,
                        "category": {
                            "id": 1,
                            "name": "Just Chatting"
                        }
                    }
                }
            }
        }, MODULE_ID);
    }

    window.TheaterController.registerModule(MODULE_ID, MODULE_DEFINITION);
})();
